    def sauvegarder_photo(self, fichier, matricule):
        import os
        from werkzeug.utils import secure_filename
        dossier = os.path.join('pointage_data', 'photos')
        os.makedirs(dossier, exist_ok=True)
        ext = os.path.splitext(fichier.filename)[1]
        nom_fichier = secure_filename(f"photo_{matricule}{ext}")
        chemin = os.path.join(dossier, nom_fichier)
        fichier.save(chemin)
        return chemin

    def purger_anciennes_donnees(self):
        try:
            duree = int(self.get_parametre('duree_conservation_mois', '12'))
        except:
            duree = 12
        date_limite = (datetime.now() - timedelta(days=30 * duree)).strftime('%Y-%m-%d')
        result = {'pointages': 0, 'retards': 0, 'logs': 0}
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute('DELETE FROM pointages WHERE date_pointage < ?', (date_limite,))
            result['pointages'] = c.rowcount
            c.execute('DELETE FROM retards_cumules WHERE date_retard < ?', (date_limite,))
            result['retards'] = c.rowcount
            date_logs = (datetime.now() - timedelta(days=90)).strftime('%Y-%m-%d %H:%M:%S')
            c.execute('DELETE FROM logs WHERE created_at < ?', (date_logs,))
            result['logs'] = c.rowcount
            conn.commit()
        return result

    def generer_rapport_presence_pdf(self, date_debut, date_fin, direction=None):
        from pdf_reports import write_report
        from flask import render_template
        import tempfile
        rapport = self.get_presence_report(date_debut, date_fin, direction)
        donnees = [dict(row) for row in rapport]
        html = render_template('rapports/rapport_presence.html',
                               titre="Rapport de présence",
                               date_debut=date_debut,
                               date_fin=date_fin,
                               donnees=donnees,
                               date_generation=datetime.now().strftime('%d/%m/%Y %H:%M'))
        with tempfile.NamedTemporaryFile(delete=False, suffix='.pdf') as tmp:
            pdf_path = tmp.name
        write_report(html, pdf_path)
        return pdf_path
