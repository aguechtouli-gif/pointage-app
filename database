    def get_retard_report(self, date_debut, date_fin, matricule=None, direction_nom=None,
                      departement_nom=None, service_nom=None, equipe_nom=None,
                      type_rapport='resume', utiliser_globaux=False):
        from datetime import datetime

        def heure_en_minutes(h):
            try:
                hh, mm, ss = map(int, h.split(':'))
                return hh * 60 + mm + ss / 60
            except:
                return 0

        debut = datetime.strptime(date_debut, '%Y-%m-%d').date()
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date()

        if utiliser_globaux:
            heure_entree_globale = self.get_parametre('heure_entree_globale', '08:00:00')
            heure_sortie_globale = self.get_parametre('heure_sortie_globale', '17:00:00')
            tolerance_entree_globale = int(self.get_parametre('tolerance_retard_globale', '0'))
            tolerance_sortie_globale = int(self.get_parametre('tolerance_depart_anticipe', '0'))
        else:
            heure_entree_globale = heure_sortie_globale = None
            tolerance_entree_globale = tolerance_sortie_globale = 0

        # Requête pour les entrées
        query_entrees = """
            SELECT p.id AS personnel_id, p.matricule, p.nom, p.prenom,
                   p.heure_entree_theorique, p.tolerance_entree,
                   p.heure_sortie_theorique, p.tolerance_sortie,
                   pt.date_pointage, pt.heure_pointage,
                   dir.nom_direction as direction_nom,
                   dep.nom_departement as departement_nom,
                   s.nom_service as service_nom,
                   e.nom_equipe as equipe_nom,
                   'entree' as type_pointage
            FROM pointages pt
            JOIN personnel p ON pt.personnel_id = p.id
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif'
              AND pt.date_pointage BETWEEN ? AND ?
              AND pt.type_pointage = 'entrée'
        """
        params_entrees = [debut, fin]

        # Requête pour les sorties
        query_sorties = """
            SELECT p.id AS personnel_id, p.matricule, p.nom, p.prenom,
                  p.heure_entree_theorique, p.tolerance_entree,
                  p.heure_sortie_theorique, p.tolerance_sortie,
                  pt.date_pointage, pt.heure_pointage,
                  dir.nom_direction as direction_nom,
                  dep.nom_departement as departement_nom,
                  s.nom_service as service_nom,
                  e.nom_equipe as equipe_nom,
                  'sortie' as type_pointage
            FROM pointages pt
            JOIN personnel p ON pt.personnel_id = p.id
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif'
              AND pt.date_pointage BETWEEN ? AND ?
              AND pt.type_pointage = 'sortie'
        """
        params_sorties = [debut, fin]

        # Ajout des filtres communs
        def ajouter_filtres(query, params, matricule, direction_nom, departement_nom, service_nom, equipe_nom):
            if matricule:
                query += " AND p.matricule LIKE ?"
                params.append(f'%{matricule}%')
            if direction_nom:
                query += " AND dir.nom_direction = ?"
                params.append(direction_nom)
            if departement_nom:
                query += " AND dep.nom_departement = ?"
                params.append(departement_nom)
            if service_nom:
                query += " AND s.nom_service = ?"
                params.append(service_nom)
            if equipe_nom:
                query += " AND e.nom_equipe = ?"
                params.append(equipe_nom)
            return query, params

        query_entrees, params_entrees = ajouter_filtres(query_entrees, params_entrees, matricule, direction_nom, departement_nom, service_nom, equipe_nom)
        query_sorties, params_sorties = ajouter_filtres(query_sorties, params_sorties, matricule, direction_nom, departement_nom, service_nom, equipe_nom)

        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_entrees, params_entrees)
            rows_entrees = c.fetchall()
            c.execute(query_sorties, params_sorties)
            rows_sorties = c.fetchall()

            penalite_par_min = float(self.get_parametre('penalite_retard', '0.50'))

            if type_rapport == 'resume':
                resume = {}
                # Traitement des entrées
                for row in rows_entrees:
                    pid = row['personnel_id']
                    if pid not in resume:
                        resume[pid] = {
                            'matricule': row['matricule'],
                            'nom': row['nom'],
                            'prenom': row['prenom'],
                            'direction': row['direction_nom'] or '',
                            'departement': row['departement_nom'] or '',
                            'service': row['service_nom'] or '',
                            'equipe': row['equipe_nom'] or '',
                            'nb_retards': 0,
                            'total_min_retard': 0,
                            'nb_departs_anticipes': 0,
                            'total_min_anticipe': 0,
                            'penalite': 0.0
                        }

                    if utiliser_globaux:
                        heure_theorique = heure_entree_globale
                        tolerance = tolerance_entree_globale
                    else:
                        heure_theorique = row['heure_entree_theorique'] or '08:00:00'
                        tolerance = row['tolerance_entree'] or 0

                    minutes_pt = heure_en_minutes(row['heure_pointage'])
                    minutes_th = heure_en_minutes(heure_theorique)
                    retard = minutes_pt - minutes_th - tolerance

                    if retard > 0:
                        resume[pid]['nb_retards'] += 1
                        resume[pid]['total_min_retard'] += retard
                        resume[pid]['penalite'] += retard * penalite_par_min

                # Traitement des sorties
                for row in rows_sorties:
                    pid = row['personnel_id']
                    if pid not in resume:
                        resume[pid] = {
                            'matricule': row['matricule'],
                            'nom': row['nom'],
                            'prenom': row['prenom'],
                            'direction': row['direction_nom'] or '',
                            'departement': row['departement_nom'] or '',
                            'service': row['service_nom'] or '',
                            'equipe': row['equipe_nom'] or '',
                            'nb_retards': 0,
                            'total_min_retard': 0,
                            'nb_departs_anticipes': 0,
                            'total_min_anticipe': 0,
                            'penalite': 0.0
                        }

                    if utiliser_globaux:
                        heure_theorique = heure_sortie_globale
                        tolerance = tolerance_sortie_globale
                    else:
                        heure_theorique = row['heure_sortie_theorique'] or '17:00:00'
                        tolerance = row['tolerance_sortie'] or 0

                    minutes_pt = heure_en_minutes(row['heure_pointage'])
                    minutes_th = heure_en_minutes(heure_theorique)
                    anticipe = minutes_th - minutes_pt - tolerance

                    if anticipe > 0:
                        resume[pid]['nb_departs_anticipes'] += 1
                        resume[pid]['total_min_anticipe'] += anticipe

                resultats = list(resume.values())
                resultats.sort(key=lambda x: x['total_min_retard'] + x['total_min_anticipe'], reverse=True)
                return resultats

            else:  # type_rapport == 'detail'
                details = []
            
                # Entrées en retard
                for row in rows_entrees:
                    if utiliser_globaux:
                        heure_theorique = heure_entree_globale
                        tolerance = tolerance_entree_globale
                    else:
                        heure_theorique = row['heure_entree_theorique'] or '08:00:00'
                        tolerance = row['tolerance_entree'] or 0

                    minutes_pt = heure_en_minutes(row['heure_pointage'])
                    minutes_th = heure_en_minutes(heure_theorique)
                    retard = minutes_pt - minutes_th - tolerance

                    if retard > 0:
                        details.append({
                            'date': row['date_pointage'],
                            'heure': row['heure_pointage'][:5] if row['heure_pointage'] else '',
                            'type': 'Entrée en retard',
                            'matricule': row['matricule'],
                            'nom': row['nom'],
                            'prenom': row['prenom'],
                            'minutes': round(retard, 2),
                            'justifie': 'Non',
                            'motif': '',
                            'direction': row['direction_nom'] or '',
                            'departement': row['departement_nom'] or '',
                            'service': row['service_nom'] or '',
                            'equipe': row['equipe_nom'] or ''
                        })

                # Sorties anticipées
                for row in rows_sorties:
                    if utiliser_globaux:
                        heure_theorique = heure_sortie_globale
                        tolerance = tolerance_sortie_globale
                    else:
                        heure_theorique = row['heure_sortie_theorique'] or '17:00:00'
                        tolerance = row['tolerance_sortie'] or 0

                    minutes_pt = heure_en_minutes(row['heure_pointage'])
                    minutes_th = heure_en_minutes(heure_theorique)
                    anticipe = minutes_th - minutes_pt - tolerance

                    if anticipe > 0:
                        details.append({
                            'date': row['date_pointage'],
                            'heure': row['heure_pointage'][:5] if row['heure_pointage'] else '',
                            'type': 'Sortie anticipée',
                            'matricule': row['matricule'],
                            'nom': row['nom'],
                            'prenom': row['prenom'],
                            'minutes': round(anticipe, 2),
                            'justifie': 'Non',
                            'motif': '',
                            'direction': row['direction_nom'] or '',
                            'departement': row['departement_nom'] or '',
                            'service': row['service_nom'] or '',
                            'equipe': row['equipe_nom'] or ''
                        })

                details.sort(key=lambda x: x['date'], reverse=True)
                return details
