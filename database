    # ------------------------------------------------------------
    # Importation de fichier pointages
    # ------------------------------------------------------------  
    def import_pointages_from_file(self, filepath, format_colonnes=None, user_id=None):
        import pandas as pd
        from datetime import datetime
        import os
        import re
        from collections import defaultdict

        results = {'total': 0, 'importes': 0, 'doublons': 0, 'erreurs': 0, 'non_concernes': 0, 'details': []}
        try:
            if not os.path.exists(filepath):
                raise Exception("Fichier non trouvé")
            if filepath.lower().endswith('.csv'):
                df = pd.read_csv(filepath, encoding='utf-8')
            else:
                df = pd.read_excel(filepath)
            results['total'] = len(df)
            print(f"[DEBUG] {len(df)} lignes lues. Colonnes : {list(df.columns)}")

            # Déterminer les colonnes
            if format_colonnes:
                matricule_col = format_colonnes.get('matricule')
                datetime_col = format_colonnes.get('datetime')
            else:
                matricule_col = None
                datetime_col = None
                for col in df.columns:
                    col_lower = col.lower()
                    if 'matricule' in col_lower:
                        matricule_col = col
                    if 'datetime' in col_lower or 'dateheure' in col_lower or 'timestamp' in col_lower:
                        datetime_col = col
                if not matricule_col:
                    matricule_col = 'matricule'
                if not datetime_col:
                    datetime_col = 'datetime'

            if matricule_col not in df.columns:
                results['erreurs'] = results['total']
                results['details'].append(f"Colonne '{matricule_col}' introuvable")
                return results
            if datetime_col not in df.columns:
                results['erreurs'] = results['total']
                results['details'].append(f"Colonne '{datetime_col}' introuvable")
                return results

            # Grouper par agent et par jour
            # Dictionnaire : (matricule_clean, date) -> liste des heures
            agent_day_points = defaultdict(list)

            # Première passe : lire toutes les lignes et collecter les heures
            for idx, row in df.iterrows():
                try:
                    brut = str(row[matricule_col]).strip()
                    if not brut or brut == 'nan':
                        results['erreurs'] += 1
                        results['details'].append(f"Ligne {idx+2}: matricule vide")
                        continue

                    # Extraction du matricule
                    match = re.match(r'^([A-Za-z0-9]+)', brut)
                    if match:
                        matricule_clean = match.group(1).upper()
                    else:
                        matricule_clean = brut.split()[0].strip().upper()

                    # Vérifier que l'agent existe (sinon on ne pourra pas importer)
                    pers = self.get_personnel_by_matricule(matricule_clean)
                    if not pers:
                        results['erreurs'] += 1
                        results['details'].append(f"Ligne {idx+2}: matricule '{matricule_clean}' inconnu")
                        continue
                    if not pers.get('concerne_pointage', 1):
                        results['non_concernes'] += 1
                        continue

                    # Conversion datetime
                    dt_val = row[datetime_col]
                    if pd.isna(dt_val):
                        results['erreurs'] += 1
                        results['details'].append(f"Ligne {idx+2}: datetime vide")
                        continue

                    if isinstance(dt_val, (int, float)):
                        dt = pd.to_datetime(dt_val, unit='D', origin='1899-12-30')
                    else:
                        dt_str = str(dt_val).strip()
                        dt_str = ' '.join(dt_str.split())
                        formats = [
                            '%d/%m/%Y %H:%M:%S', '%d/%m/%Y %H:%M', '%Y-%m-%d %H:%M:%S',
                            '%Y-%m-%d %H:%M', '%d/%m/%Y', '%Y-%m-%d'
                        ]
                        dt = None
                        for fmt in formats:
                            try:
                                dt = datetime.strptime(dt_str, fmt)
                                break
                            except:
                                continue
                        if dt is None:
                            try:
                                dt = pd.to_datetime(dt_str)
                            except:
                                results['erreurs'] += 1
                                results['details'].append(f"Ligne {idx+2}: datetime invalide '{dt_str}'")
                            continue

                    date_pt = dt.date()
                    heure_pt = dt.time()

                    # Stocker pour ce (matricule_clean, date)
                    key = (matricule_clean, date_pt, pers['id'])
                    agent_day_points[key].append((heure_pt, brut, pers))

                except Exception as e:
                    results['erreurs'] += 1
                    results['details'].append(f"Ligne {idx+2}: {str(e)}")
                    print(f"[ERROR] Ligne {idx+2}: {e}")

            # Deuxième passe : pour chaque (agent, date), prendre min et max
            with self.get_connection() as conn:
                cursor = conn.cursor()
                for (matricule_clean, date_pt, personnel_id), points in agent_day_points.items():
                    if len(points) == 0:
                        continue
                    # Trier par heure
                    points.sort(key=lambda x: x[0])
                    # Heure min -> entrée, heure max -> sortie
                    heure_entree = points[0][0]
                    brut_entree = points[0][1]
                    pers = points[0][2]
                    heure_sortie = points[-1][0]
                    brut_sortie = points[-1][1]

                    # Insérer l'entrée
                    cursor.execute('''
                        INSERT INTO pointages (personnel_id, matricule, badge_id, type_pointage, date_pointage, heure_pointage, mode, user_id)
                        VALUES (?,?,?,?,?,?,?,?)
                    ''', (pers['id'], brut_entree, pers.get('badge_id'), 'entrée', date_pt, heure_entree.strftime('%H:%M:%S'), 'import', user_id))
                    results['importes'] += 1

                    # Insérer la sortie si différente de l'entrée (même heure ? au cas où un seul pointage)
                    if heure_entree != heure_sortie:
                        cursor.execute('''
                            INSERT INTO pointages (personnel_id, matricule, badge_id, type_pointage, date_pointage, heure_pointage, mode, user_id)
                            VALUES (?,?,?,?,?,?,?,?)
                        ''', (pers['id'], brut_sortie, pers.get('badge_id'), 'sortie', date_pt, heure_sortie.strftime('%H:%M:%S'), 'import', user_id))
                        results['importes'] += 1
                    else:
                        results['details'].append(f"Agent {matricule_clean} le {date_pt}: un seul pointage, importé comme entrée uniquement")
                conn.commit()

        except Exception as e:
            results['erreurs'] = results['total']
            results['details'].append(f"Erreur globale: {str(e)}")
            print(f"[ERROR] {e}")
        return results


