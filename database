    def get_retards_avec_filtres(self, agent_id=None, direction=None, departement=None,
                                 service=None, equipe=None, date_debut=None, date_fin=None):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            query = """
                SELECT r.matricule, p.nom, p.prenom,
                       dir.nom_direction as direction,
                       dep.nom_departement as departement,
                       s.nom_service as service,
                       e.nom_equipe as equipe,
                       COUNT(r.id) as nb_retards,
                       SUM(r.minutes_retard) as total_min,
                       SUM(CASE WHEN r.est_justifie = 1 THEN r.minutes_retard ELSE 0 END) as justifie,
                       SUM(CASE WHEN r.est_justifie = 0 THEN r.minutes_retard ELSE 0 END) as non_justifie
                FROM retards_cumules r
                JOIN personnel p ON r.personnel_id = p.id
                LEFT JOIN directions dir ON p.direction_id = dir.id
                LEFT JOIN departements dep ON p.departement_id = dep.id
                LEFT JOIN services s ON p.service_id = s.id
                LEFT JOIN equipes e ON p.equipe_id = e.id
                WHERE 1=1
            """
            params = []
            if agent_id:
                query += " AND p.id = ?"
                params.append(agent_id)
            if direction:
                query += " AND dir.nom_direction = ?"
                params.append(direction)
            if departement:
                query += " AND dep.nom_departement = ?"
                params.append(departement)
            if service:
                query += " AND s.nom_service = ?"
                params.append(service)
            if equipe:
                query += " AND e.nom_equipe = ?"
                params.append(equipe)
            if date_debut and date_fin:
                query += " AND r.date_retard BETWEEN ? AND ?"
                params.extend([date_debut, date_fin])
            query += " GROUP BY r.personnel_id ORDER BY total_min DESC"
            cursor.execute(query, params)
            return [dict(row) for row in cursor.fetchall()]

    def get_absences_avec_filtres(self, agent=None, direction=None, departement=None,
                                  service=None, equipe=None, date_debut=None, date_fin=None):
        from datetime import datetime, timedelta
        debut = datetime.strptime(date_debut, '%Y-%m-%d').date() if date_debut else None
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date() if date_fin else None
        if not debut or not fin:
            return []

        query_agents = """
            SELECT p.id, p.matricule, p.nom, p.prenom,
                   dir.nom_direction as direction,
                   dep.nom_departement as departement,
                   s.nom_service as service,
                   e.nom_equipe as equipe
            FROM personnel p
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif'
        """
        params_agents = []
        if agent and agent != 'Tous':
            query_agents += " AND (p.matricule LIKE ? OR p.nom LIKE ? OR p.prenom LIKE ?)"
            params_agents.extend([f'%{agent}%', f'%{agent}%', f'%{agent}%'])
        if direction and direction != 'Toutes':
            query_agents += " AND dir.nom_direction = ?"
            params_agents.append(direction)
        if departement and departement != 'Tous':
            query_agents += " AND dep.nom_departement = ?"
            params_agents.append(departement)
        if service and service != 'Tous':
            query_agents += " AND s.nom_service = ?"
            params_agents.append(service)
        if equipe and equipe != 'Toutes':
            query_agents += " AND e.nom_equipe = ?"
            params_agents.append(equipe)

        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params_agents)
            agents = c.fetchall()

            resultats = []
            for agent in agents:
                jours_ouvres = self._calculer_jours_ouvres(debut, fin)
                nb_jours_ouvres = len(jours_ouvres)

                c.execute("""
                    SELECT COUNT(DISTINCT date_pointage)
                    FROM pointages
                    WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                """, (agent['id'], debut, fin))
                nb_pointes = c.fetchone()[0] or 0

                c.execute("""
                    SELECT SUM(
                        julianday(MIN(date_fin, ?)) - julianday(MAX(date_debut, ?)) + 1
                    )
                    FROM conges
                    WHERE personnel_id = ? AND statut = 'approuve'
                        AND date_debut <= ? AND date_fin >= ?
                """, (fin, debut, agent['id'], fin, debut))
                nb_conges = c.fetchone()[0] or 0
                nb_conges = int(round(nb_conges))

                absences = nb_jours_ouvres - nb_pointes - nb_conges
                if absences < 0:
                    absences = 0

                resultats.append({
                    'matricule': agent['matricule'],
                    'nom': agent['nom'],
                    'prenom': agent['prenom'],
                    'direction': agent['direction'] or '',
                    'departement': agent['departement'] or '',
                    'service': agent['service'] or '',
                    'equipe': agent['equipe'] or '',
                    'jours_ouvres': nb_jours_ouvres,
                    'pointes': nb_pointes,
                    'conges': nb_conges,
                    'absences': absences
                })

            return resultats

