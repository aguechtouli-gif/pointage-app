    # ------------------------------------------------------------
    # Gestion des utilisateurs
    # ------------------------------------------------------------
    def create_user(self, username, password, nom, prenom, email=None, role='utilisateur'):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            hashed = hashlib.sha256(password.encode()).hexdigest()
            cursor.execute('''
                INSERT INTO utilisateurs (username, password, nom, prenom, email, role, is_active)
                VALUES (?,?,?,?,?,?,1)
            ''', (username, hashed, nom, prenom, email, role))
            conn.commit()
            return cursor.lastrowid

    def authenticate_user(self, username, password):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            hashed = hashlib.sha256(password.encode()).hexdigest()
            cursor.execute('SELECT * FROM utilisateurs WHERE username=? AND password=?', (username, hashed))
            user = cursor.fetchone()
            if user:
                cursor.execute('UPDATE utilisateurs SET last_login=? WHERE id=?', (datetime.now(), user['id']))
                conn.commit()
                return dict(user)
            return None

    def get_all_users(self):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute('SELECT * FROM utilisateurs ORDER BY nom, prenom')
            return [dict(row) for row in cursor.fetchall()]

    def get_user(self, user_id):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            cursor.execute('SELECT * FROM utilisateurs WHERE id=?', (user_id,))
            row = cursor.fetchone()
            return dict(row) if row else None

    def update_user(self, user_id, **kwargs):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            set_clause = ', '.join([f"{k}=?" for k in kwargs])
            vals = list(kwargs.values()) + [user_id]
            cursor.execute(f'UPDATE utilisateurs SET {set_clause} WHERE id=?', vals)
            conn.commit()
            return cursor.rowcount > 0

    # ------------------------------------------------------------
    # Gestion du personnel
    # ------------------------------------------------------------
    def get_personnel(self, id=None):
        query = """
            SELECT p.*,
                   a.nom_activite as activite_nom,
                   d.nom_division as division_nom,
                   dir.nom_direction as direction_nom,
                   dep.nom_departement as departement_nom,
                   s.nom_service as service_nom,
                   e.nom_equipe as equipe_nom,
                   q.nom_quart as quart_nom
            FROM personnel p
            LEFT JOIN activites a ON p.activite_id = a.id
            LEFT JOIN divisions d ON p.division_id = d.id
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            LEFT JOIN quarts_travail q ON p.quart_id = q.id
        """
        if id:
            query += " WHERE p.id = ?"
            with self.get_connection() as conn:
                c = conn.cursor()
                c.execute(query, (id,))
                row = c.fetchone()
                return dict(row) if row else None
        else:
            query += " ORDER BY p.nom, p.prenom"
            with self.get_connection() as conn:
                c = conn.cursor()
                c.execute(query)
                return [dict(row) for row in c.fetchall()]

    def get_personnel_by_matricule(self, matricule='matricule'):
        with self.get_connection() as conn:
            c = conn.cursor()
            # Nettoyage : on prend la partie avant le premier espace (si présent)
            # pour extraire le vrai matricule
            brut = matricule.strip()
            # On cherche d'abord une correspondance exacte sur le matricule stocké
            c.execute("SELECT * FROM personnel WHERE TRIM(UPPER(matricule)) = ?", (brut.upper(),))
            row = c.fetchone()
            if row:
                return dict(row)
            # Sinon, on cherche si le début de la chaîne correspond au matricule stocké
            # (utile pour "EMP001 DUPONT Jean" vs "EMP001")
            first_word = brut.split()[0].upper() if brut else ''
            if first_word:
                c.execute("SELECT * FROM personnel WHERE TRIM(UPPER(matricule)) = ?", (first_word,))
                row = c.fetchone()
                if row:
                    return dict(row)
            # Dernier recours : LIKE avec le début
            c.execute("SELECT * FROM personnel WHERE ? LIKE TRIM(UPPER(matricule)) || '%'", (brut.upper(),))
            row = c.fetchone()
            return dict(row) if row else None

    def get_personnel_by_badge(self, badge_id):
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT * FROM personnel WHERE TRIM(UPPER(badge_id)) = ?", (badge_id.strip().upper(),))
            row = c.fetchone()
            return dict(row) if row else None

