    #------------------------------------------------------------
    # Rapport de présence avec filtres avancés
    #------------------------------------------------------------
    def get_presence_report(self, date_debut, date_fin, matricule=None, direction_nom=None,
                        departement_nom=None, service_nom=None, equipe_nom=None,
                        type_rapport='resume'):
        from datetime import datetime, timedelta
    
        debut = datetime.strptime(date_debut, '%Y-%m-%d').date()
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date()
    
        # Calcul du nombre total de jours ouvrés dans la période (pour le taux de présence)
        def est_weekend(d):
            jours_weekend = [5, 6]  # Samedi=5, Dimanche=6 (adjust according to your config)
            return d.weekday() in jours_weekend
    
        def est_ferie(d):
            with self.get_connection() as conn:
                c = conn.cursor()
                c.execute("SELECT COUNT(*) FROM jours_feries WHERE date_jour = ?", (d,))
                return c.fetchone()[0] > 0
    
        # Générer la liste des dates de la période
        toutes_dates = []
        jour = debut
        while jour <= fin:
            toutes_dates.append(jour)
            jour += timedelta(days=1)
    
        # Requête pour récupérer les agents avec leurs infos
        query_agents = """
            SELECT p.id, p.matricule, p.nom, p.prenom, p.fonction,
                 dir.nom_direction as direction,
                 dep.nom_departement as departement,
                 s.nom_service as service,
                 e.nom_equipe as equipe
            FROM personnel p
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif' AND p.concerne_pointage = 1
        """
        params_agents = []
        if matricule:
            query_agents += " AND p.matricule = ?"
            params_agents.append(matricule)
        if direction_nom:
            query_agents += " AND dir.nom_direction = ?"
            params_agents.append(direction_nom)
        if departement_nom:
            query_agents += " AND dep.nom_departement = ?"
            params_agents.append(departement_nom)
        if service_nom:
            query_agents += " AND s.nom_service = ?"
            params_agents.append(service_nom)
        if equipe_nom:
            query_agents += " AND e.nom_equipe = ?"
            params_agents.append(equipe_nom)
    
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params_agents)
            agents = c.fetchall()
        
            if type_rapport == 'resume':
                resultats = []
                for agent in agents:
                    # Compter les jours de présence (au moins un pointage par jour)
                    c.execute("""
                        SELECT COUNT(DISTINCT date_pointage) as jours
                        FROM pointages
                        WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                    """, (agent['id'], debut, fin))
                    row = c.fetchone()
                    jours_presence = row['jours'] or 0
                
                    # Calculer le taux de présence (basé sur jours ouvrés)
                    jours_ouvres = 0
                    for d in toutes_dates:
                        if not est_weekend(d) and not est_ferie(d):
                            jours_ouvres += 1
                    taux = (jours_presence / jours_ouvres * 100) if jours_ouvres > 0 else 0
                
                    resultats.append({
                        'matricule': agent['matricule'],
                        'nom': agent['nom'],
                        'prenom': agent['prenom'],
                        'fonction': agent['fonction'],
                        'direction': agent['direction'] or '',
                        'departement': agent['departement'] or '',
                        'service': agent['service'] or '',
                        'equipe': agent['equipe'] or '',
                        'jours_presence': jours_presence,
                        'taux_presence': round(taux, 1)
                    })
                return resultats
        
            else:  # type_rapport == 'detail'
                details = []
                for agent in agents:
                    # Récupérer les pointages pour chaque jour de la période
                    for date_pt in toutes_dates:
                        c.execute("""
                            SELECT heure_pointage, type_pointage
                            FROM pointages
                            WHERE personnel_id = ? AND date_pointage = ?
                            ORDER BY heure_pointage
                        """, (agent['id'], date_pt))
                        pointages = c.fetchall()
                    
                        heure_entree = None
                        heure_sortie = None
                        for pt in pointages:
                            if pt['type_pointage'] == 'entrée':
                                heure_entree = pt['heure_pointage'][:5] if pt['heure_pointage'] else None
                            elif pt['type_pointage'] == 'sortie':
                                heure_sortie = pt['heure_pointage'][:5] if pt['heure_pointage'] else None
                    
                        details.append({
                            'date': date_pt.strftime('%Y-%m-%d'),
                            'matricule': agent['matricule'],
                            'nom': agent['nom'],
                            'prenom': agent['prenom'],
                            'direction': agent['direction'] or '',
                            'departement': agent['departement'] or '',
                            'service': agent['service'] or '',
                            'equipe': agent['equipe'] or '',
                            'present': len(pointages) > 0,
                            'heure_entree': heure_entree or '-',
                            'heure_sortie': heure_sortie or '-'
                        })
                return details
    
    #------------------------------------------------------------
    # Rapport d'absence avec filtres avancés
    #------------------------------------------------------------
    def get_absence_report(self, date_debut, date_fin, matricule=None, utilisateur_id=None,
                           direction_nom=None, departement_nom=None, service_nom=None, equipe_nom=None,
                           type_rapport=None):
        debut = datetime.strptime(date_debut, '%Y-%m-%d').date()
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date()

        query_agents = """
            SELECT p.id, p.matricule, p.nom, p.prenom, p.fonction,
                   dir.nom_direction as direction,
                   dep.nom_departement as departement,
                   s.nom_service as service,
                   e.nom_equipe as equipe
            FROM personnel p
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif' AND p.concerne_pointage = 1
        """
        params_agents = []
        if matricule:
            query_agents += " AND p.matricule = ?"
            params_agents.append(matricule)
        if utilisateur_id:
            query_agents += " AND p.id = ?"
            params_agents.append(utilisateur_id)
        if direction_nom:
            query_agents += " AND dir.nom_direction = ?"
            params_agents.append(direction_nom)
        if departement_nom:
            query_agents += " AND dep.nom_departement = ?"
            params_agents.append(departement_nom)
        if service_nom:
            query_agents += " AND s.nom_service = ?"
            params_agents.append(service_nom)
        if equipe_nom:
            query_agents += " AND e.nom_equipe = ?"
            params_agents.append(equipe_nom)

        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params_agents)
            agents = c.fetchall()

            resultats = []
            for agent in agents:
                jours_ouvres = self._calculer_jours_ouvres(debut, fin)
                nb_jours_ouvres = len(jours_ouvres)

                c.execute("""
                    SELECT COUNT(DISTINCT date_pointage)
                    FROM pointages
                    WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                """, (agent['id'], debut, fin))
                nb_pointes = c.fetchone()[0] or 0

                c.execute("""
                    SELECT SUM(
                        julianday(MIN(date_fin, ?)) - julianday(MAX(date_debut, ?)) + 1
                    )
                    FROM conges
                    WHERE personnel_id = ? AND statut = 'approuve'
                        AND date_debut <= ? AND date_fin >= ?
                """, (fin, debut, agent['id'], fin, debut))
                nb_conges = c.fetchone()[0] or 0
                nb_conges = int(round(nb_conges))

                absences = nb_jours_ouvres - nb_pointes - nb_conges
                if absences < 0:
                    absences = 0

                resultats.append({
                    'matricule': agent['matricule'],
                    'nom': agent['nom'],
                    'prenom': agent['prenom'],
                    'direction': agent['direction'] or '',
                    'departement': agent['departement'] or '',
                    'service': agent['service'] or '',
                    'equipe': agent['equipe'] or '',
                    'jours_ouvres': nb_jours_ouvres,
                    'pointes': nb_pointes,
                    'conges': nb_conges,
                    'absences': absences
                })
            return resultats

    def _calculer_jours_ouvres(self, debut, fin):
        jours = []
        jour = debut
        while jour <= fin:
            if not self.est_weekend(jour) and not self.est_jour_ferie(jour):
                jours.append(jour)
            jour += timedelta(days=1)
        return jours

