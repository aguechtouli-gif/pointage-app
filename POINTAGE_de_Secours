class ConfigWeekendDialog:
    def __init__(self, parent, app):
        self.app = app
        self.dialog = tk.Toplevel(parent)
        self.dialog.title("Configuration des jours de weekend")
        self.dialog.geometry("400x300")
        self.dialog.transient(parent)
        self.dialog.grab_set()

        tk.Label(self.dialog, text="Sélectionnez les jours considérés comme weekend :",
                 font=('Arial', 11, 'bold')).pack(pady=10)

        jours = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche']
        # indices: lundi=0, mardi=1, mercredi=2, jeudi=3, vendredi=4, samedi=5, dimanche=6
        self.vars = []
        frame = tk.Frame(self.dialog)
        frame.pack(pady=10)
        for i, jour in enumerate(jours):
            var = tk.BooleanVar()
            self.vars.append(var)
            cb = tk.Checkbutton(frame, text=jour, variable=var)
            cb.grid(row=i//3, column=i%3, sticky='w', padx=10, pady=5)

        # Charger la configuration actuelle
        actuel = self.app.db.get_parametre('jours_weekend', '5,6')
        indices = [int(x.strip()) for x in actuel.split(',') if x.strip()]
        for i in indices:
            if 0 <= i < len(self.vars):
                self.vars[i].set(True)

        btn_frame = tk.Frame(self.dialog)
        btn_frame.pack(pady=20)
        tk.Button(btn_frame, text="Enregistrer", command=self.sauvegarder,
                  bg='#27ae60', fg='white', width=15).pack(side=tk.LEFT, padx=10)
        tk.Button(btn_frame, text="Annuler", command=self.dialog.destroy,
                  bg='#e74c3c', fg='white', width=15).pack(side=tk.LEFT, padx=10)

    def sauvegarder(self):
        indices = [str(i) for i, var in enumerate(self.vars) if var.get()]
        nouvelle_valeur = ','.join(indices)
        self.app.db.set_parametre('jours_weekend', nouvelle_valeur)
        messagebox.showinfo("Succès", "Configuration des jours de weekend enregistrée.")
        self.dialog.destroy()


