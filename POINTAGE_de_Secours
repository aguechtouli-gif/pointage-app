    def filtrer_personnel_dashboard(self):
        search = self.dash_search.get().strip()
        direction = self.dash_direction.get()
        if direction == 'Toutes':
            direction = None
        departement = self.dash_departement.get()
        if departement == 'Tous':
            departement = None
        service = self.dash_service.get()
        if service == 'Tous':
            service = None
        equipe = self.dash_equipe.get()
        if equipe == 'Tous':
            equipe = None

        query = """
            SELECT p.matricule, p.nom, p.prenom, p.fonction,
               dir.nom_direction as direction,
               departement_id, service_id, equipe_id, p.statut
               FROM personnel p
               LEFT JOIN directions dir ON p.direction_id = dir.id
               WHERE p.statut = 'actif'
        """
        params = []
        if search:
            query += " AND (p.matricule LIKE ? OR p.nom LIKE ? OR p.prenom LIKE ?)"
            search_param = f'%{search}%'
            params.extend([search_param, search_param, search_param])
        if direction:
            query += " AND dir.nom_direction = ?"
            params.append(direction)
        if departement:
            query += " AND dep.nom_departement = ?"
            params.append(departement)
        if service:
            query += " AND s.nom_service = ?"
            params.append(service)
        if equipe:
            query += " AND p.equipe = ?"
            params.append(equipe)
        query += " LIMIT 50"

        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute(query, params)
            rows = c.fetchall()
        for item in self.dash_tree.get_children():
            self.dash_tree.delete(item)
        for r in rows:
            self.dash_tree.insert('', 'end', values=(
                r['matricule'], r['nom'], r['prenom'], r['fonction'],
                r['direction'] or '', r['departement'] or '', r['service'] or '', r['equipe'] or '',
                r['statut']
            ))


