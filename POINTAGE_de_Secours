    def generer_rapport(self):
        try:
            debut = self.date_debut.get_date()
            fin = self.date_fin.get_date()
            if debut > fin:
                messagebox.showwarning("Attention", "La date de début doit être antérieure à la date de fin")
                return

            matricule = self.matricule_var.get().strip()
            direction = self.direction_var.get()
            departement = self.departement_var.get()
            service = self.service_var.get()
            equipe = self.equipe_var.get()

            query_agents = "SELECT id, matricule, nom, prenom FROM personnel WHERE statut = 'actif'"
            params_agents = []

            if matricule:
                query_agents += " AND matricule LIKE ?"
                params_agents.append(f'%{matricule}%')
            else:
                if direction and direction != 'Toutes':
                    query_agents += " AND direction = ?"
                    params_agents.append(direction)
                if departement and departement != 'Tous':
                    query_agents += " AND departement = ?"
                    params_agents.append(departement)
                if service and service != 'Tous':
                    query_agents += " AND service = ?"
                    params_agents.append(service)
                if equipe and equipe != 'Toutes':
                    query_agents += " AND equipe = ?"
                    params_agents.append(equipe)

            with self.app.db.get_connection() as conn:
                c = conn.cursor()
                c.execute(query_agents, params_agents)
                agents = c.fetchall()

            if not agents:
                messagebox.showinfo("Info", "Aucun agent ne correspond aux filtres")
                return

            self.resultats = []
            for agent in agents:
                c.execute("""
                    SELECT COUNT(DISTINCT date_pointage) as jours
                    FROM pointages
                    WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                """, (agent['id'], debut, fin))
                row = c.fetchone()
                jours = row['jours'] or 0

                self.resultats.append({
                    'matricule': agent['matricule'],
                    'nom': agent['nom'],
                    'prenom': agent['prenom'],
                    'direction': direction or '',
                    'departement': departement or '',
                    'service': service or '',
                    'equipe': equipe or '',
                    'jours_presence': jours
                })

            self.resultats.sort(key=lambda x: (x['nom'], x['prenom']))

            for item in self.tree.get_children():
                self.tree.delete(item)

            for r in self.resultats:
                self.tree.insert('', 'end', values=(
                    r['matricule'],
                    r['nom'],
                    r['prenom'],
                    r['direction'],
                    r['departement'],
                    r['service'],
                    r['equipe'],
                    r['jours_presence']
                ))

        except Exception as e:
            messagebox.showerror("Erreur", f"Erreur lors du calcul : {e}")

