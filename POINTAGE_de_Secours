# ------------------------------------------------------------
# Fonction dataframe_to_pdf (export PDF)
# ------------------------------------------------------------
def dataframe_to_pdf(df, titre, filename, orientation='portrait',
                     logo_path=None, pied_page=None,
                     color_conditions=None, col_widths=None):
    """
    Exporte un DataFrame pandas en PDF avec options avancées.
    df : DataFrame à exporter
    titre : titre du rapport
    filename : chemin du fichier de sortie
    orientation : 'portrait' ou 'landscape'
    logo_path : chemin vers une image (logo) à placer en haut à droite
    pied_page : texte à afficher en bas de page (peut contenir \n)
    color_conditions : liste de tuples (colonne, condition, couleur)
        exemple: [('absences', lambda x: x > 5, colors.red)]
    col_widths : liste des largeurs de colonnes (en cm) ou dictionnaire {col: largeur}
    """
    if orientation == 'landscape':
        pagesize = landscape(A4)
    else:
        pagesize = A4

    doc = SimpleDocTemplate(filename, pagesize=pagesize,
                            rightMargin=2*cm, leftMargin=2*cm,
                            topMargin=2.5*cm, bottomMargin=2.5*cm)

    elements = []

    # Logo et titre
    styles = getSampleStyleSheet()
    title_style = styles['Title']
    normal_style = styles['Normal']

    if logo_path and os.path.exists(logo_path):
        try:
            logo = RLImage(logo_path, width=3*cm, height=2*cm)
            # Utiliser une table pour aligner logo à droite et titre à gauche
            header_data = [[Paragraph(titre, title_style), logo]]
            header_table = Table(header_data, colWidths=[15*cm, 4*cm])
            header_table.setStyle(TableStyle([
                ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
                ('ALIGN', (0,0), (0,0), 'LEFT'),
                ('ALIGN', (1,0), (1,0), 'RIGHT'),
            ]))
            elements.append(header_table)
        except:
            elements.append(Paragraph(titre, title_style))
    else:
        elements.append(Paragraph(titre, title_style))
    elements.append(Spacer(1, 0.5*cm))

    # Préparation des données du tableau
    data = [df.columns.tolist()] + df.values.tolist()

    # Déterminer les largeurs de colonnes
    if col_widths is None:
        col_widths = [2.5] * len(df.columns)  # valeur par défaut
    elif isinstance(col_widths, dict):
        # Si dictionnaire, on applique les largeurs données, les autres automatiques
        auto_widths = []
        for j, col in enumerate(df.columns):
            if col in col_widths:
                auto_widths.append(col_widths[col] * cm)
            else:
                max_len = max(len(str(data[i][j])) for i in range(len(data)))
                auto_widths.append(max_len * 0.15 * cm)
        col_widths = auto_widths
    else:
        col_widths = [w * cm for w in col_widths]

    table = Table(data, colWidths=col_widths, repeatRows=1)

    # Style de base
    style = TableStyle([
        ('BACKGROUND', (0,0), (-1,0), colors.grey),
        ('TEXTCOLOR', (0,0), (-1,0), colors.whitesmoke),
        ('ALIGN', (0,0), (-1,-1), 'CENTER'),
        ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
        ('FONTSIZE', (0,0), (-1,0), 12),
        ('BOTTOMPADDING', (0,0), (-1,0), 8),
        ('BACKGROUND', (0,1), (-1,-1), colors.beige),
        ('GRID', (0,0), (-1,-1), 1, colors.black),
        ('FONTSIZE', (0,1), (-1,-1), 9),
        ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
    ])

    # Appliquer les couleurs conditionnelles
    if color_conditions:
        for col_name, condition, color in color_conditions:
            if col_name in df.columns:
                col_index = df.columns.get_loc(col_name) + 1  # +1 car data[0] est l'en-tête
                for i, row in enumerate(data[1:], start=1):
                    try:
                        if condition(row[col_index-1]):
                            style.add('BACKGROUND', (col_index, i), (col_index, i), color)
                    except:
                        pass

    table.setStyle(style)
    elements.append(table)

    # Pied de page
    if pied_page:
        elements.append(Spacer(1, 0.5*cm))
        style_pied = getSampleStyleSheet()['Normal']
        style_pied.alignment = 1  # Centré
        style_pied.fontSize = 8
        elements.append(Paragraph(pied_page, style_pied))

    doc.build(elements)

