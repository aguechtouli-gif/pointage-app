        tk.Button(btn_frame, text="❌ ANNULER", command=self.fermer,
                  bg="#e74c3c", fg='white', width=15).pack(side=tk.LEFT, padx=10, expand=True)

    def parcourir_fichier(self):
        filename = filedialog.askopenfilename(
            title="Sélectionner le fichier de pointages",
            filetypes=[("CSV", "*.csv"), ("Excel", "*.xlsx *.xls"), ("Tous", "*.*")]
        )
        if filename:
            self.file_path.set(filename)
            self.afficher_apercu(filename)

    def afficher_apercu(self, filename):
        self.preview_text.delete(1.0, tk.END)
        try:
            if filename.lower().endswith('.csv'):
                df = pd.read_csv(filename, nrows=5)
            else:
                df = pd.read_excel(filename, nrows=5)
            self.preview_text.insert(tk.END, "📋 APERÇU DES 5 PREMIÈRES LIGNES:\n\n")
            self.preview_text.insert(tk.END, df.to_string())
            self.preview_text.insert(tk.END, f"\n\n✅ Fichier: {os.path.basename(filename)}")
            self.preview_text.insert(tk.END, f"\n📊 Colonnes détectées: {', '.join(df.columns)}")
            
            # Suggestion automatique
            for col in df.columns:
                col_lower = col.lower()
                if 'matricule' in col_lower:
                    self.matricule_entry.delete(0, tk.END)
                    self.matricule_entry.insert(0, col)
                elif 'datetime' in col_lower or 'dateheure' in col_lower or 'timestamp' in col_lower:
                    self.datetime_entry.delete(0, tk.END)
                    self.datetime_entry.insert(0, col)
        except Exception as e:
            self.preview_text.insert(tk.END, f"❌ Erreur de lecture: {str(e)}")

    def importer(self):
        fichier = self.file_path.get().strip()
        if not fichier:
            messagebox.showwarning("Attention", "Veuillez sélectionner un fichier")
            return

        matricule_col = self.matricule_entry.get().strip()
        datetime_col = self.datetime_entry.get().strip()
        if not matricule_col or not datetime_col:
            messagebox.showwarning("Attention", "Veuillez spécifier les colonnes matricule et datetime")
            return

        mapping = {'matricule': matricule_col, 'datetime': datetime_col}

        if not messagebox.askyesno("Confirmation", "Lancer l'importation des pointages ?"):
            return

        try:
            self.preview_text.delete(1.0, tk.END)
            self.preview_text.insert(tk.END, "⏳ Importation en cours...")
            self.window.update()

            results = self.app.db.import_pointages_from_file(
                filepath=fichier,
                format_colonnes=mapping,
                user_id=self.app.current_user['id'] if self.app.current_user else None
            )

            result_text = f"""
📊 RÉSULTATS DE L'IMPORTATION
{'='*50}
✅ Fichier: {os.path.basename(fichier)}
• Total lignes: {results['total']}
• ✅ Importés: {results['importes']}
• ⚠️ Doublons: {results['doublons']}
• ❌ Erreurs: {results['erreurs']}
"""
            self.preview_text.delete(1.0, tk.END)
            self.preview_text.insert(tk.END, result_text)
            resultats=results.get('details', [])
            if resultats:
                self.preview_text.insert(tk.END, "\n📋 Détails des erreurs (max 20):\n")
                for detail in resultats[:20]:
                    self.preview_text.insert(tk.END, f"• {detail}\n")
                    
        

            messagebox.showinfo("Import terminé", f"{results['importes']} pointages importés, {results['erreurs']} erreurs.")
            if results['erreurs'] == 0:
                if messagebox.askyesno("Succès", "Fermer la fenêtre ?"):
                    self.fermer()
        except Exception as e:
            messagebox.showerror("Erreur", f"Erreur: {str(e)}")

    def fermer(self):
        if self.window:
            self.window.destroy()


