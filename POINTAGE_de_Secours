    def generer_rapport(self):
        try:
            debut = self.date_debut.get_date()
            fin = self.date_fin.get_date()
            if debut > fin:
                messagebox.showwarning("Attention", "La date de début doit être antérieure à la date de fin")
                return

            matricule = self.matricule_var.get().strip()
            direction = self.direction_var.get()
            departement = self.departement_var.get()
            service = self.service_var.get()
            equipe = self.equipe_var.get()

            query_agents = """
                SELECT p.id, p.matricule, p.nom, p.prenom,
                   dir.nom_direction as direction,
                   dep.nom_departement as departement,
                   s.nom_service as service,
                   e.nom_equipe as equipe
                FROM personnel p
                LEFT JOIN directions dir ON p.direction_id = dir.id
                LEFT JOIN departements dep ON p.departement_id = dep.id
                LEFT JOIN services s ON p.service_id = s.id
                LEFT JOIN equipes e ON p.equipe_id = e.id
                WHERE p.statut = 'actif'
            """
            params_agents = []

            if matricule:
                query_agents += " AND matricule LIKE ?"
                params_agents.append(f'%{matricule}%')
            else:
                if direction and direction != 'Toutes':
                    query_agents += " AND direction = ?"
                    params_agents.append(direction)
                if departement and departement != 'Tous':
                    query_agents += " AND departement = ?"
                    params_agents.append(departement)
                if service and service != 'Tous':
                    query_agents += " AND service = ?"
                    params_agents.append(service)
                if equipe and equipe != 'Toutes':
                    query_agents += " AND equipe = ?"
                    params_agents.append(equipe)

            with self.app.db.get_connection() as conn:
                c = conn.cursor()
                c.execute(query_agents, params_agents)
                agents = c.fetchall()

            if not agents:
                messagebox.showinfo("Info", "Aucun agent ne correspond aux filtres")
                return

            penalite_par_min = float(self.app.db.get_parametre('penalite_retard', '0.50'))
            self.resultats = []

            for agent in agents:
                c.execute("""
                    SELECT COUNT(id) as nb_retards,
                           COALESCE(SUM(minutes_retard), 0) as total_min,
                           COALESCE(SUM(CASE WHEN est_justifie = 1 THEN minutes_retard ELSE 0 END), 0) as justifie,
                           COALESCE(SUM(CASE WHEN est_justifie = 0 THEN minutes_retard ELSE 0 END), 0) as non_justifie
                    FROM retards_cumules
                    WHERE personnel_id = ? AND date_retard BETWEEN ? AND ?
                """, (agent['id'], debut, fin))
                row = c.fetchone()
                nb_retards = row['nb_retards'] or 0
                total_min = row['total_min'] or 0
                justifie = row['justifie'] or 0
                non_justifie = row['non_justifie'] or 0
                penalite = non_justifie * penalite_par_min

                if nb_retards > 0:           
                    self.resultats.append({
                        'matricule': agent['matricule'],
                        'nom': agent['nom'],
                        'prenom': agent['prenom'],
                        'direction': agent['direction'] or '',
                        'departement': agent['departement'] or '',
                        'service': agent['service'] or '',
                        'equipe': agent['equipe'] or '',
                        'nb_retards': nb_retards,
                        'total_min': total_min,
                        'justifie': justifie,
                        'non_justifie': non_justifie,
                        'penalite': penalite
                    })

            self.resultats.sort(key=lambda x: x['total_min'], reverse=True)

            for item in self.tree.get_children():
                self.tree.delete(item)

            for r in self.resultats:
                self.tree.insert('', 'end', values=(
                    r['matricule'],
                    r['nom'],
                    r['prenom'],
                    r['direction'],
                    r['departement'],
                    r['service'],
                    r['equipe'],
                    r['nb_retards'],
                    f"{r['total_min']} min",
                    f"{r['justifie']} min",
                    f"{r['non_justifie']} min",
                    f"{r['penalite']:.2f} €"
                ))

        except Exception as e:
            messagebox.showerror("Erreur", f"Erreur lors du calcul : {e}")

