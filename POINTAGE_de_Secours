            self.equipe_combo['values'] = [e['nom'] for e in equipes]
            self.id_maps['equipe'] = {e['nom']: e['id'] for e in equipes}

            quarts = self.app.db.get_all_quarts()
            self.quart_combo['values'] = [q['nom'] for q in quarts]
            self.id_maps['quart'] = {q['nom']: q['id'] for q in quarts}
