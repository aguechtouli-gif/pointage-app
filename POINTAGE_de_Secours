    def show_dashboard(self):
        self.clear_content()

        canvas = tk.Canvas(self.content_frame, bg='#ecf0f1', highlightthickness=0)
        scrollbar = tk.Scrollbar(self.content_frame, orient="vertical", command=canvas.yview)
        scrollable_frame = tk.Frame(canvas, bg='#ecf0f1')
        scrollable_frame.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.create_window((0, 0), window=scrollable_frame, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")

        stats = self.app.db.get_statistiques_completes()

        cards_frame = tk.Frame(scrollable_frame, bg='#ecf0f1')
        cards_frame.pack(fill=tk.X, padx=20, pady=10)
        cards = [
            ("👥 Personnel actif", stats.get('personnel_actif', 0), "#3498db"),
            ("🎯 Concernés pointage", stats.get('personnel_concerne', 0), "#2ecc71"),
            ("⏰ Pointages (mois)", stats.get('pointages_periode', 0), "#e74c3c"),
            ("⚠️ Retards (mois)", f"{stats.get('retards_periode', 0)} ({stats.get('minutes_retard_periode', 0)} min)", "#f39c12"),
        ]
        for i, (title, value, color) in enumerate(cards):
            card = tk.Frame(cards_frame, bg=color, relief=tk.RAISED, bd=2, height=100, width=200)
            card.grid(row=0, column=i, padx=10, pady=10, sticky='nsew')
            card.grid_propagate(False)
            cards_frame.columnconfigure(i, weight=1)
            tk.Label(card, text=str(value), font=('Arial', 20, 'bold'), bg=color, fg='white').pack(expand=True)
            tk.Label(card, text=title, font=('Arial', 10), bg=color, fg='white').pack()

        graph_frame = tk.Frame(scrollable_frame, bg='#ecf0f1')
        graph_frame.pack(fill=tk.BOTH, expand=True, padx=20, pady=20)
        
        from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
        from matplotlib.figure import Figure
        
        fig = Figure(figsize=(12, 5), dpi=100)
        fig.subplots_adjust(hspace=0.4, wspace=0.3)
        ax1 = fig.add_subplot(121)
        
        # Dans show_dashboard, remplacer la requête pour le graphique par :
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("""
                SELECT dir.nom_direction, COUNT(p.id)
                FROM personnel p
                LEFT JOIN directions dir ON p.direction_id = dir.id
                WHERE p.statut='actif'
                GROUP BY dir.nom_direction
            """)
            directions = {row[0] or 'Sans direction': row[1] for row in c.fetchall()}
        if directions:
            ax1.pie(directions.values(), labels=directions.keys(), autopct='%1.1f%%', startangle=90)
            ax1.set_title("Répartition par direction")
        else:
            ax1.text(0.5, 0.5, "Aucune donnée", ha='center', va='center')
            ax1.set_title("Répartition par direction")
        ax2 = fig.add_subplot(122)
        date_fin = date.today()
        date_debut = date_fin - timedelta(days=30)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("""
                SELECT date_pointage, COUNT(*)
                FROM pointages
                WHERE date_pointage BETWEEN ? AND ?
                GROUP BY date_pointage
                ORDER BY date_pointage
            """, (date_debut, date_fin))
            rows = c.fetchall()
            dates = [r[0] for r in rows]
            counts = [r[1] for r in rows]
        if dates:
            ax2.plot(dates, counts, marker='o', linestyle='-', color='#3498db')
            ax2.set_title("Pointages des 30 derniers jours")
            ax2.set_xlabel("Date")
            ax2.set_ylabel("Nombre")
            ax2.tick_params(axis='x', rotation=45)
        else:
            ax2.text(0.5, 0.5, "Aucune donnée", ha='center', va='center')
            ax2.set_title("Pointages des 30 derniers jours")
        canvas_graph = FigureCanvasTkAgg(fig, graph_frame)
        canvas_graph.draw()
        canvas_graph.get_tk_widget().pack(fill=tk.BOTH, expand=True)

        # Filtre rapide personnel
        filter_section = tk.LabelFrame(scrollable_frame, text="🔍 Recherche rapide du personnel",
                                font=('Arial', 12, 'bold'), bg='white')
        filter_section.pack(fill=tk.X, padx=20, pady=10)
        filtres_frame = tk.Frame(filter_section, bg='white')
        filtres_frame.pack(fill=tk.X, padx=10, pady=5)
        
        tk.Label(filtres_frame, text="Recherche (nom, matricule) :", bg='white').grid(row=0, column=0, padx=5, pady=5, sticky='w')
        self.dash_search = tk.Entry(filtres_frame, width=20)
        self.dash_search.grid(row=0, column=1, padx=5, pady=5)
        
        tk.Label(filtres_frame, text="Direction :", bg='white').grid(row=0, column=2, padx=5, pady=5, sticky='w')
        self.dash_direction = ttk.Combobox(filtres_frame, width=18)
        self.dash_direction.grid(row=0, column=3, padx=5, pady=5)
        
        # Récupérer les directions distinctes depuis personnel (colonne texte)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT DISTINCT dir.nom_direction FROM personnel p LEFT JOIN directions dir ON p.direction_id = dir.id WHERE dir.nom_direction IS NOT NULL ORDER BY dir.nom_direction")
            dirs = [row[0] for row in c.fetchall()]
        self.dash_direction['values'] = ['Toutes'] + dirs
        self.dash_direction.set('Toutes')
        
        tk.Label(filtres_frame, text="Département :", bg='white').grid(row=0, column=4, padx=5, pady=5, sticky='w')
        self.dash_departement = ttk.Combobox(filtres_frame, width=18)
        self.dash_departement.grid(row=0, column=5, padx=5, pady=5)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT DISTINCT dep.nom_departement FROM personnel p LEFT JOIN departements dep ON p.departement_id = dep.id WHERE dep.nom_departement IS NOT NULL ORDER BY dep.nom_departement")
            depts = [row[0] for row in c.fetchall()]
        self.dash_departement['values'] = ['Tous'] + depts
        self.dash_departement.set('Tous')
        
        tk.Label(filtres_frame, text="Service :", bg='white').grid(row=0, column=6, padx=5, pady=5, sticky='w')
        self.dash_service = ttk.Combobox(filtres_frame, width=18)
        self.dash_service.grid(row=0, column=7, padx=5, pady=5)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT DISTINCT s.nom_service FROM personnel p LEFT JOIN services s ON p.service_id = s.id WHERE s.nom_service IS NOT NULL ORDER BY s.nom_service")
            servs = [row[0] for row in c.fetchall()]
        self.dash_service['values'] = ['Tous'] + servs
        self.dash_service.set('Tous')
        
        tk.Label(filtres_frame, text="Équipe :", bg='white').grid(row=0, column=8, padx=5, pady=5, sticky='w')
        self.dash_equipe = ttk.Combobox(filtres_frame, width=18)
        self.dash_equipe.grid(row=0, column=9, padx=5, pady=5)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT DISTINCT eq.nom_equipe FROM personnel p LEFT JOIN equipes eq ON p.equipe_id = eq.id WHERE eq.nom_equipe IS NOT NULL ORDER BY eq.nom_equipe")
            eqs = [row[0] for row in c.fetchall()]
        self.dash_equipe['values'] = ['Toutes'] + eqs
        self.dash_equipe.set('Toutes')
        
        tk.Button(filtres_frame, text="🔍 Filtrer", command=self.filtrer_personnel_dashboard,
                  bg='#3498db', fg='white', font=('Arial', 9, 'bold')).grid(row=0, column=10, padx=10, pady=5)

        tree_frame = tk.Frame(filter_section, bg='white')
        tree_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        columns = ('Matricule', 'Nom', 'Prénom', 'Fonction', 'Direction', 'Département', 'Service', 'Équipe', 'Statut')
        self.dash_tree = ttk.Treeview(tree_frame, columns=columns, show='headings', height=8)
        for col in columns:
            self.dash_tree.heading(col, text=col)
            self.dash_tree.column(col, width=100)
        self.dash_tree.column('Nom', width=120)
        self.dash_tree.column('Prénom', width=120)
        vsb = ttk.Scrollbar(tree_frame, orient=tk.VERTICAL, command=self.dash_tree.yview)
        self.dash_tree.configure(yscrollcommand=vsb.set)
        self.dash_tree.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        vsb.pack(side=tk.RIGHT, fill=tk.Y)
        self.filtrer_personnel_dashboard()

        # Top 5 retardataires (corrigé)
        top_frame = tk.LabelFrame(scrollable_frame, text="🚨 Top 5 des retardataires (mois en cours)",
                                   font=('Arial', 12, 'bold'), bg='white')
        top_frame.pack(fill=tk.BOTH, expand=True, padx=20, pady=10)
        cols = ('Matricule', 'Nom', 'Prénom', 'Direction', 'Nb retards', 'Total minutes')
        tree = ttk.Treeview(top_frame, columns=cols, show='headings', height=5)
        for col in cols:
            tree.heading(col, text=col)
            tree.column(col, width=100)
        tree.column('Nom', width=120)
        tree.column('Prénom', width=120)
        aujourdhui = date.today()
        premier_jour = aujourdhui.replace(day=1)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute("""
                SELECT r.matricule, p.nom, p.prenom, p.direction_id as direction,
                       COUNT(r.id) as nb_retards,
                       SUM(r.minutes_retard) as total_min
                FROM retards_cumules r
                JOIN personnel p ON r.personnel_id = p.id
                WHERE r.date_retard BETWEEN ? AND ?
                GROUP BY r.personnel_id
                ORDER BY total_min DESC
                LIMIT 5
            """, (premier_jour, aujourdhui))
            for row in c.fetchall():
                tree.insert('', 'end', values=(
                    row['matricule'], row['nom'], row['prenom'], row['direction'] or '',
                    row['nb_retards'], f"{row['total_min']} min"
                ))
        scrollbar_top = ttk.Scrollbar(top_frame, orient=tk.VERTICAL, command=tree.yview)
        tree.configure(yscrollcommand=scrollbar_top.set)
        tree.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5, pady=5)
        scrollbar_top.pack(side=tk.RIGHT, fill=tk.Y)

        # Derniers pointages
        last_frame = tk.LabelFrame(scrollable_frame, text="⏱️ Derniers pointages",
