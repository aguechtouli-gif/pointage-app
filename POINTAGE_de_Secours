    def _afficher_details(self, demande_id):
        try:
            with self.app.db.get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute('''
                    SELECT c.*, p.nom, p.prenom, p.fonction,
                           dir.nom_direction as direction,
                           s.nom_service as service
                    FROM conges c
                    JOIN personnel p ON c.personnel_id = p.id
                    LEFT JOIN directions dir ON p.direction_id = dir.id
                    LEFT JOIN services s ON p.service_id = s.id
                    WHERE c.id = ?
                ''', (demande_id,))
