    def exporter(self):
        typ = self.type_var.get()
        fmt = self.format_var.get()
        data = None
        if typ == 'personnel':
            data = self.get_personnel_data()
        elif typ == 'pointages':
            data = self.get_pointages_data()
        elif typ == 'retards':
            data = self.get_retards_data()
        elif typ == 'absences':
            data = self.get_absences_data()
        elif typ == 'presence':
            data = self.get_presence_data()
        if data is None or data.empty:
            messagebox.showwarning("Attention", "Aucune donnée à exporter.")
            return
        ext = {'csv': '.csv', 'excel': '.xlsx', 'pdf': '.pdf'}[fmt]
        filename = filedialog.asksaveasfilename(defaultextension=ext,
                                                filetypes=[(fmt.upper(), f"*{ext}")])
        if not filename:
            return
        try:
            if fmt == 'csv':
                data.to_csv(filename, index=False, encoding='utf-8-sig')
            elif fmt == 'excel':
                data.to_excel(filename, index=False)
            elif fmt == 'pdf':
                self.export_pdf(data, filename)
            messagebox.showinfo("Succès", f"Export terminé vers {filename}")
            self.window.destroy()
        except Exception as e:
            messagebox.showerror("Erreur", f"Erreur lors de l'export : {e}")

    def get_personnel_data(self):
        personnel = self.app.db.get_personnel()
        if not personnel:
            return None
        df = pd.DataFrame([dict(p) for p in personnel])
        cols = ['matricule', 'badge_id', 'nom', 'prenom', 'type_person', 'fonction',
                'direction_nom', 'departement_nom', 'service_nom', 'equipe_nom', 'statut',
                'concerne_pointage', 'type_quart', 'heure_entree_theorique', 'heure_sortie_theorique',
                'tolerance_entree', 'tolerance_sortie']
        cols_present = [c for c in cols if c in df.columns]
        return df[cols_present]

    def get_pointages_data(self):
        date_debut = self.date_debut.get_date().strftime('%Y-%m-%d')
        date_fin = self.date_fin.get_date().strftime('%Y-%m-%d')
        pointages = self.app.db.get_pointages_filtres(date_debut=date_debut, date_fin=date_fin)
        if not pointages:
            return None
        df = pd.DataFrame([dict(p) for p in pointages])
        cols = ['id', 'matricule', 'type_pointage', 'date_pointage', 'heure_pointage',
                'mode', 'justification', 'minutes_retard', 'est_weekend', 'est_jour_ferie']
        cols_present = [c for c in cols if c in df.columns]
        return df[cols_present]

    def get_retards_data(self):
        date_debut = self.date_debut.get_date().strftime('%Y-%m-%d')
        date_fin = self.date_fin.get_date().strftime('%Y-%m-%d')
        direction = None if self.direction_combo.get() == 'Toutes' else self.direction_combo.get()
        agent_sel = self.agent_combo.get() if hasattr(self, 'agent_combo') else 'Tous'
        import re
        matricule = None
        if agent_sel != 'Tous':
            match = re.search(r'\(([^)]+)\)', agent_sel)
            if match:
                matricule = match.group(1)
        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            query = '''
                SELECT r.id, r.matricule, p.nom, p.prenom, r.date_retard, r.minutes_retard,
                       r.est_justifie, r.justification, r.mois, r.annee,
                       dir.nom_direction as direction
                FROM retards_cumules r
                JOIN personnel p ON r.personnel_id = p.id
                LEFT JOIN directions dir ON p.direction_id = dir.id
                WHERE r.date_retard BETWEEN ? AND ?
            '''
            params = [date_debut, date_fin]
            if direction:
                query += ' AND dir.nom_direction = ?'
                params.append(direction)
            if matricule:
                query += ' AND r.matricule = ?'
                params.append(matricule)
            query += ' ORDER BY r.date_retard DESC'
            c.execute(query, params)
            rows = c.fetchall()
        if not rows:
            return None
        return pd.DataFrame([dict(r) for r in rows])

    def get_absences_data(self):
        date_debut = self.date_debut.get_date()
        date_fin = self.date_fin.get_date()
        direction = None if self.direction_combo.get() == 'Toutes' else self.direction_combo.get()
        departement = None if self.departement_combo.get() == 'Tous' else self.departement_combo.get()
        service = None if self.service_combo.get() == 'Tous' else self.service_combo.get()
        equipe = None if self.equipe_combo.get() == 'Toutes' else self.equipe_combo.get()

        query_agents = '''
            SELECT p.id, p.matricule, p.nom, p.prenom,
                   dir.nom_direction as direction,
                   dep.nom_departement as departement,
                   s.nom_service as service,
                   e.nom_equipe as equipe
            FROM personnel p
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif'
        '''
        params = []
        if direction:
            query_agents += ' AND dir.nom_direction = ?'
            params.append(direction)
        if departement:
            query_agents += ' AND dep.nom_departement = ?'
            params.append(departement)
        if service:
            query_agents += ' AND s.nom_service = ?'
            params.append(service)
        if equipe:
            query_agents += ' AND e.nom_equipe = ?'
            params.append(equipe)

        with self.app.db.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params)
            agents = c.fetchall()
        if not agents:
            return None

        def est_weekend(d):
            return d.weekday() in (4,5)
        def est_ferie(d):
            with self.app.db.get_connection() as conn2:
                cur = conn2.cursor()
                cur.execute("SELECT COUNT(*) FROM jours_feries WHERE date_jour=?", (d,))
                return cur.fetchone()[0] > 0

        resultats = []
        jour = date_debut
        while jour <= date_fin:
            if not est_weekend(jour) and not est_ferie(jour):
                for a in agents:
                    c.execute("SELECT COUNT(*) FROM pointages WHERE personnel_id=? AND date_pointage=?", (a['id'], jour))
                    a_pointe = c.fetchone()[0] > 0
                    c.execute('''
                        SELECT COUNT(*) FROM conges WHERE personnel_id=? AND statut='approuve'
                        AND date_debut <= ? AND date_fin >= ?
                    ''', (a['id'], jour, jour))
                    a_conge = c.fetchone()[0] > 0
                    if not a_pointe and not a_conge:
                        resultats.append({
                            'date': jour.strftime('%Y-%m-%d'),
                            'matricule': a['matricule'],
                            'nom': a['nom'],
                            'prenom': a['prenom'],
                            'direction': a['direction'] or '',
                            'departement': a['departement'] or '',
                            'service': a['service'] or '',
                            'equipe': a['equipe'] or ''
                        })
            jour += timedelta(days=1)
        if not resultats:
            return None
        return pd.DataFrame(resultats)

    def get_presence_data(self):
        date_debut = self.date_debut.get_date().strftime('%Y-%m-%d')
        date_fin = self.date_fin.get_date().strftime('%Y-%m-%d')
        direction = None if self.direction_combo.get() == 'Toutes' else self.direction_combo.get()
        rapport = self.app.db.get_presence_report(date_debut, date_fin, direction_nom=direction)
        if not rapport:
            return None
        df = pd.DataFrame([dict(r) for r in rapport])
        return df

    def export_pdf(self, df, filename):
        from pdf_reports import write_report
        from jinja2 import Template
        template_html = '''
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="UTF-8">
            <title>Export des données</title>
            <style>
                body { font-family: Arial, sans-serif; }
                h1 { color: #2c3e50; }
                table { border-collapse: collapse; width: 100%; }
                th { background-color: #3498db; color: white; padding: 8px; }
                td { border: 1px solid #ddd; padding: 8px; }
                tr:nth-child(even) { background-color: #f2f2f2; }
            </style>
        </head>
        <body>
            <h1>Export des données - {{ type }}</h1>
            <p>Généré le {{ date }}</p>
            {{ table|safe }}
        </body>
        </html>
        '''
        template = Template(template_html)
        html = template.render(type=self.type_var.get(),
                               date=datetime.now().strftime('%d/%m/%Y %H:%M'),
                               table=df.to_html(index=False))
        write_report(html, filename)

