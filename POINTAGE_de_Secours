            self.id_maps['activite'] = {a['nom']: a['id'] for a in activites}

            divisions = self.app.db.get_all_divisions()
            self.division_combo['values'] = [d['nom'] for d in divisions]
            self.id_maps['division'] = {d['nom']: d['id'] for d in divisions}

            directions = self.app.db.get_all_directions()
            self.direction_combo['values'] = [d['nom'] for d in directions]
            self.id_maps['direction'] = {d['nom']: d['id'] for d in directions}

            departements = self.app.db.get_all_departements()
            self.departement_combo['values'] = [d['nom'] for d in departements]
            self.id_maps['departement'] = {d['nom']: d['id'] for d in departements}

            services = self.app.db.get_all_services()
            self.service_combo['values'] = [s['nom'] for s in services]
            self.id_maps['service'] = {s['nom']: s['id'] for s in services}

