            print(f"Erreur chargement listes: {e}")

    def choisir_photo(self):
        file_path = filedialog.askopenfilename(
            title="Sélectionner une photo",
            filetypes=[("Images", "*.png *.jpg *.jpeg *.gif")]
        )
        if file_path:
            self.photo_path = file_path
            self.afficher_photo(file_path)

    def afficher_photo(self, path):
        try:
            img = Image.open(path)
            canvas_width = 150
            canvas_height = 150
            img.thumbnail((canvas_width, canvas_height), Image.LANCZOS)
            self.photo_image = ImageTk.PhotoImage(img)
            self.photo_canvas.delete("all")
            x = (canvas_width - img.width) // 2
            y = (canvas_height - img.height) // 2
            self.photo_canvas.create_image(x, y, anchor=tk.NW, image=self.photo_image)
        except Exception as e:
            messagebox.showerror("Erreur", f"Impossible de charger l'image : {e}")

    def load_data(self):
        pers = self.personnel
        if not pers:
            return
        self.matricule_var.set(pers['matricule'])
        self.badge_var.set(pers.get('badge_id', ''))
        self.nom_var.set(pers['nom'])
        self.prenom_var.set(pers['prenom'])
        self.type_person_var.set(pers.get('type_person', 'cadre'))
        if pers.get('date_naissance'):
            self.date_naissance.set_date(datetime.strptime(pers['date_naissance'], '%Y-%m-%d'))
        self.fonction_var.set(pers.get('fonction', ''))
        # Sélectionner les noms à partir des IDs
        if pers.get('activite_id'):
            for nom, id_ in self.id_maps.get('activite', {}).items():
                if id_ == pers['activite_id']:
                    self.activite_var.set(nom)
                    break
        if pers.get('division_id'):
            for nom, id_ in self.id_maps.get('division', {}).items():
                if id_ == pers['division_id']:
                    self.division_var.set(nom)
                    break
        if pers.get('direction_id'):
            for nom, id_ in self.id_maps.get('direction', {}).items():
                if id_ == pers['direction_id']:
                    self.direction_var.set(nom)
                    break
        if pers.get('departement_id'):
            for nom, id_ in self.id_maps.get('departement', {}).items():
                if id_ == pers['departement_id']:
                    self.departement_var.set(nom)
                    break
        if pers.get('service_id'):
            for nom, id_ in self.id_maps.get('service', {}).items():
                if id_ == pers['service_id']:
                    self.service_var.set(nom)
                    break
        if pers.get('equipe_id'):
            for nom, id_ in self.id_maps.get('equipe', {}).items():
                if id_ == pers['equipe_id']:
                    self.equipe_var.set(nom)
                    break
        if pers.get('quart_id'):
            for nom, id_ in self.id_maps.get('quart', {}).items():
                if id_ == pers['quart_id']:
                    self.quart_var.set(nom)
                    break
        if pers.get('date_embauche'):
            self.date_embauche.set_date(datetime.strptime(pers['date_embauche'], '%Y-%m-%d'))
        self.statut_var.set(pers.get('statut', 'actif'))
        self.concerne_var.set(bool(pers.get('concerne_pointage', 1)))
        self.type_quart_var.set(pers.get('type_quart', 'jour'))
        self.heure_entree_var.set(pers.get('heure_entree_theorique', '08:00:00'))
        self.heure_sortie_var.set(pers.get('heure_sortie_theorique', '17:00:00'))
        self.tolerance_entree_var.set(pers.get('tolerance_entree', 10))
        self.tolerance_sortie_var.set(pers.get('tolerance_sortie', 10))
        self.adresse_var.set(pers.get('adresse', ''))
        self.telephone_var.set(pers.get('telephone', ''))
        self.email_var.set(pers.get('email', ''))
        self.photo_actuelle = pers.get('photo')
        if self.photo_actuelle:
            self.photo_path = self.photo_actuelle
            self.afficher_photo(self.photo_actuelle)

    def save(self):
        if not all([self.matricule_var.get(), self.nom_var.get(), self.prenom_var.get(),
                    self.fonction_var.get(), self.direction_var.get()]):
            messagebox.showwarning("Validation", "Veuillez remplir tous les champs obligatoires (*)")
            return

        activite_id = self.id_maps.get('activite', {}).get(self.activite_var.get())
        division_id = self.id_maps.get('division', {}).get(self.division_var.get())
        direction_id = self.id_maps.get('direction', {}).get(self.direction_var.get())
        departement_id = self.id_maps.get('departement', {}).get(self.departement_var.get())
        service_id = self.id_maps.get('service', {}).get(self.service_var.get())
        equipe_id = self.id_maps.get('equipe', {}).get(self.equipe_var.get())
        quart_id = self.id_maps.get('quart', {}).get(self.quart_var.get())

        photo = None
        if hasattr(self, 'photo_path') and self.photo_path:
            dossier = os.path.join('pointage_data', 'photos')
            os.makedirs(dossier, exist_ok=True)
            ext = os.path.splitext(self.photo_path)[1]
            nom_fichier = f"photo_{self.matricule_var.get()}_{datetime.now().strftime('%Y%m%d%H%M%S')}{ext}"
            chemin = os.path.join(dossier, nom_fichier)
            img = Image.open(self.photo_path)
            img.save(chemin)
            photo = chemin
        else:
            photo = self.photo_actuelle if hasattr(self, 'photo_actuelle') else None

        data = (
            self.matricule_var.get().strip(),
            self.badge_var.get().strip() or None,
            self.nom_var.get().strip().upper(),
            self.prenom_var.get().strip().title(),
            self.type_person_var.get(),
            self.fonction_var.get().strip(),
            activite_id,
            division_id,
            direction_id,
            departement_id,
            service_id,
            equipe_id,
            self.date_embauche.get_date().strftime('%Y-%m-%d') if self.date_embauche.get() else None,
            self.date_naissance.get_date().strftime('%Y-%m-%d') if self.date_naissance.get() else None,
            self.adresse_var.get().strip() or None,
            self.telephone_var.get().strip() or None,
            self.email_var.get().strip() or None,
            photo,
            self.statut_var.get(),
            1 if self.concerne_var.get() else 0,
            self.type_quart_var.get(),
            self.heure_entree_var.get().strip() or '08:00:00',
            self.heure_sortie_var.get().strip() or '17:00:00',
            self.tolerance_entree_var.get(),
            self.tolerance_sortie_var.get()
        )

        try:
            if self.personnel_id:
                self.app.db.update_personnel(self.personnel_id, data)
                messagebox.showinfo("Succès", "Personnel modifié avec succès.")
            else:
                self.app.db.add_personnel(data)
                messagebox.showinfo("Succès", "Personnel ajouté avec succès.")
            self.result = True
            self.dialog.destroy()
        except sqlite3.IntegrityError as e:
            if 'matricule' in str(e):
                messagebox.showerror("Erreur", "Ce matricule existe déjà.")
            elif 'badge_id' in str(e):
                messagebox.showerror("Erreur", "Ce badge ID est déjà utilisé.")
            else:
                messagebox.showerror("Erreur", f"Doublon détecté : {e}")
        except Exception as e:
            messagebox.showerror("Erreur", f"Erreur lors de l'enregistrement : {e}")


