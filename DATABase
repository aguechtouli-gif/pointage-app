    def get_statistiques_completes(self):
        stats = {}
        today = date.today()
        premier_jour_mois = today.replace(day=1)
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT COUNT(*) FROM personnel WHERE statut='actif'")
            stats['personnel_actif'] = c.fetchone()[0] or 0
            c.execute("SELECT COUNT(*) FROM personnel WHERE concerne_pointage=1 AND statut='actif'")
            stats['personnel_concerne'] = c.fetchone()[0] or 0
            c.execute("SELECT COUNT(*) FROM pointages WHERE date_pointage BETWEEN ? AND ?", (premier_jour_mois, today))
            stats['pointages_periode'] = c.fetchone()[0] or 0
            c.execute("SELECT COUNT(*), SUM(minutes_retard) FROM retards_cumules WHERE date_retard BETWEEN ? AND ?", (premier_jour_mois, today))
            row = c.fetchone()
            stats['retards_periode'] = row[0] or 0
            stats['minutes_retard_periode'] = row[1] or 0
            c.execute("""
                SELECT pt.*, p.matricule, p.nom, p.prenom, p.fonction,
                       dir.nom_direction as direction_nom,
                       COALESCE((
                            SELECT SUM(minutes_retard) FROM retards_cumules 
                            WHERE personnel_id = pt.personnel_id AND date_retard = pt.date_pointage
                       ), 0) as minutes_retard
                       
                FROM pointages pt
                JOIN personnel p ON pt.personnel_id = p.id
                LEFT JOIN directions dir ON p.direction_id = dir.id
                ORDER BY pt.date_pointage DESC, pt.heure_pointage DESC
                LIMIT 20
            """)
            stats['derniers_pointages'] = [dict(row) for row in c.fetchall()]
        return stats

