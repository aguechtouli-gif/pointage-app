    def get_parametre(self, cle, defaut=''):
        """Récupère la valeur d'un paramètre depuis la table parametres"""
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT valeur FROM parametres WHERE cle = ?", (cle,))
            row = c.fetchone()
            if row:
                return row['valeur']
            return defaut

    def set_parametre(self, cle, valeur):
        """Enregistre ou met à jour un paramètre dans la table parametres"""
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute("SELECT COUNT(*) FROM parametres WHERE cle = ?", (cle,))
            if c.fetchone()[0] > 0:
                c.execute("UPDATE parametres SET valeur = ?, updated_at = CURRENT_TIMESTAMP WHERE cle = ?", (valeur, cle))
            else:
                c.execute("INSERT INTO parametres (cle, valeur) VALUES (?, ?)", (cle, valeur))
            conn.commit()
