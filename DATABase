    def get_retards_avec_filtres(self, agent_id=None, direction=None, departement=None,
                                 service=None, equipe=None, date_debut=None, date_fin=None):
        with self.get_connection() as conn:
            cursor = conn.cursor()
            query = """
                SELECT r.matricule, p.nom, p.prenom,
                       dir.nom_direction as direction,
                       dep.nom_departement as departement,
                       s.nom_service as service,
                       e.nom_equipe as equipe,
                       COUNT(r.id) as nb_retards,
                       SUM(r.minutes_retard) as total_min,
                       SUM(CASE WHEN r.est_justifie = 1 THEN r.minutes_retard ELSE 0 END) as justifie,
                       SUM(CASE WHEN r.est_justifie = 0 THEN r.minutes_retard ELSE 0 END) as non_justifie
                FROM retards_cumules r
                JOIN personnel p ON r.personnel_id = p.id
                LEFT JOIN directions dir ON p.direction_id = dir.id
                LEFT JOIN departements dep ON p.departement_id = dep.id
                LEFT JOIN services s ON p.service_id = s.id
                LEFT JOIN equipes e ON p.equipe_id = e.id
                WHERE 1=1
            """
            params = []
            if agent_id:
                query += " AND p.id = ?"
                params.append(agent_id)
            if direction:
                query += " AND dir.nom_direction = ?"
                params.append(direction)
            if departement:
                query += " AND dep.nom_departement = ?"
                params.append(departement)
            if service:
                query += " AND s.nom_service = ?"
                params.append(service)
            if equipe:
                query += " AND e.nom_equipe = ?"
                params.append(equipe)
            if date_debut and date_fin:
                query += " AND r.date_retard BETWEEN ? AND ?"
                params.extend([date_debut, date_fin])
            query += " GROUP BY r.personnel_id ORDER BY total_min DESC"
            cursor.execute(query, params)
            return [dict(row) for row in cursor.fetchall()]

