    # ------------------------------------------------------------
    # Importation de fichier personnel
    # ------------------------------------------------------------
    def import_pointages_from_file(self, filepath, format_colonnes=None, user_id=None, progress_callback=None):
        import pandas as pd
        from datetime import datetime
        import os
        import re

        results = {'total': 0, 'importes': 0, 'doublons': 0, 'erreurs': 0, 'non_concernes': 0, 'details': []}
    
        if progress_callback:
            progress_callback(5, "Vérification du fichier...")
    
        try:
            if not os.path.exists(filepath):
                raise Exception("Fichier non trouvé")
        
            # Déterminer le format du fichier
            if filepath.lower().endswith('.csv'):
                df = pd.read_csv(filepath, encoding='utf-8')
            else:
                df = pd.read_excel(filepath)
        
            results['total'] = len(df)
            print(f"[DEBUG] {len(df)} lignes lues. Colonnes : {list(df.columns)}")
        
            if progress_callback:
                progress_callback(10, f"Fichier lu : {len(df)} lignes")

            # Détection automatique ou utilisation des colonnes fournies
            if format_colonnes:
                matricule_col = format_colonnes.get('matricule')
                datetime_col = format_colonnes.get('datetime')
            else:
                matricule_col = None
                datetime_col = None
                for col in df.columns:
                    col_lower = col.lower()
                    if 'matricule' in col_lower:
                        matricule_col = col
                    if 'datetime' in col_lower or 'dateheure' in col_lower or 'timestamp' in col_lower:
                        datetime_col = col
                if not matricule_col:
                    matricule_col = 'matricule'
                if not datetime_col:
                    datetime_col = 'datetime'

            if matricule_col not in df.columns:
                results['erreurs'] = results['total']
                results['details'].append(f"Colonne '{matricule_col}' introuvable")
                return results
            if datetime_col not in df.columns:
                results['erreurs'] = results['total']
                results['details'].append(f"Colonne '{datetime_col}' introuvable")
                return results

            # Prétraitement : grouper par matricule et date pour optimiser
            grouped_data = {}
        
            if progress_callback:
                progress_callback(15, "Prétraitement des données...")

            # Première passe : structurer les données par (matricule_clean, date)
            for idx, row in df.iterrows():
                if progress_callback and idx % 1000 == 0:
                    progress = 15 + int((idx / max(len(df), 1)) * 30)
                    progress_callback(min(progress, 45), f"Traitement ligne {idx+1}/{len(df)}...")
            
                try:
                    brut = str(row[matricule_col]).strip()
                    if not brut or brut == 'nan':
                        results['erreurs'] += 1
                        results['details'].append(f"Ligne {idx+2}: matricule vide")
                        continue

                    # Extraction du matricule (premiers caractères alphanumériques)
                    match = re.match(r'^([A-Za-z0-9]+)', brut)
                    if match:
                        matricule_clean = match.group(1).upper()
                    else:
                        matricule_clean = brut.split()[0].strip().upper()

                    # Vérification de l'existence de l'agent
                    pers = self.get_personnel_by_matricule(matricule_clean)
                    if not pers:
                        results['erreurs'] += 1
                        results['details'].append(f"Ligne {idx+2}: matricule '{matricule_clean}' inconnu")
                        continue
                
                    if not pers.get('concerne_pointage', 1):
                        results['non_concernes'] += 1
                        continue

                    dt_val = row[datetime_col]
                    if pd.isna(dt_val):
                        results['erreurs'] += 1
                        results['details'].append(f"Ligne {idx+2}: datetime vide")
                        continue

                    # Conversion datetime robuste
                    if isinstance(dt_val, (int, float)):
                       dt = pd.to_datetime(dt_val, unit='D', origin='1899-12-30')
                    else:
                        dt_str = str(dt_val).strip()
                        dt_str = ' '.join(dt_str.split())
                        formats = [
                            '%d/%m/%Y %H:%M:%S', '%d/%m/%Y %H:%M', '%Y-%m-%d %H:%M:%S',
                            '%Y-%m-%d %H:%M', '%d/%m/%Y', '%Y-%m-%d', '%d/%m/%Y %H:%M:%S',
                            '%Y-%m-%dT%H:%M:%S', '%Y-%m-%dT%H:%M'
                        ]
                        dt = None
                        for fmt in formats:
                            try:
                                dt = datetime.strptime(dt_str, fmt)
                                break
                            except:
                                continue
                        if dt is None:
                            try:
                                dt = pd.to_datetime(dt_str)
                            except:
                                results['erreurs'] += 1
                                results['details'].append(f"Ligne {idx+2}: datetime invalide '{dt_str}'")
                                continue

                    date_pt = dt.date()
                    heure_pt = dt.time()
                
                    key = (pers['id'], date_pt)
                    if key not in grouped_data:
                        grouped_data[key] = {'heures': [], 'brut': brut, 'pers': pers}
                    grouped_data[key]['heures'].append(heure_pt)
                
                except Exception as e:
                    results['erreurs'] += 1
                    results['details'].append(f"Ligne {idx+2}: {str(e)}")

            if progress_callback:
                progress_callback(50, "Insertion en base de données...")

            # Deuxième passe : insertion avec gestion entrée/sortie
            with self.get_connection() as conn:
                cursor = conn.cursor()
                processed = 0
                total_items = len(grouped_data)
            
                for (personnel_id, date_pt), data in grouped_data.items():
                    processed += 1
                    if progress_callback and processed % 10 == 0:
                        progress = 50 + int((processed / max(total_items, 1)) * 40)
                        progress_callback(min(progress, 90), f"Insertion {processed}/{total_items}...")
                
                    heures = sorted(data['heures'])
                    pers = data['pers']
                    brut = data['brut']
                
                    if len(heures) == 0:
                        continue
                
                    # Premier pointage = entrée
                    heure_entree = heures[0]
                    cursor.execute('''
                        INSERT INTO pointages (personnel_id, matricule, badge_id, type_pointage, date_pointage, heure_pointage, mode, user_id)
                        VALUES (?,?,?,?,?,?,?,?)
                    ''', (pers['id'], brut, pers.get('badge_id'), 'entrée', date_pt, heure_entree.strftime('%H:%M:%S'), 'import', user_id))
                    results['importes'] += 1
                
                    # Dernier pointage = sortie (si différent)
                    if len(heures) > 1 and heure_entree != heures[-1]:
                        heure_sortie = heures[-1]
                        cursor.execute('''
                            INSERT INTO pointages (personnel_id, matricule, badge_id, type_pointage, date_pointage, heure_pointage, mode, user_id)
                            VALUES (?,?,?,?,?,?,?,?)
                        ''', (pers['id'], brut, pers.get('badge_id'), 'sortie', date_pt, heure_sortie.strftime('%H:%M:%S'), 'import', user_id))
                        results['importes'] += 1
                
                    conn.commit()
            
                if progress_callback:
                    progress_callback(95, "Finalisation...")
        
            if progress_callback:
                progress_callback(100, f"Import terminé : {results['importes']} pointages")
        
            return results
        
        except Exception as e:
            results['erreurs'] = results['total']
            results['details'].append(f"Erreur globale: {str(e)}")
            if progress_callback:
                progress_callback(100, f"Erreur : {str(e)}")
            return results

