    def determiner_quart(self, heure_str):
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute("""
                SELECT id, nom_quart FROM quarts_travail
                WHERE heure_debut <= ? AND heure_fin >= ?
                ORDER BY est_nuit DESC, id LIMIT 1
            """, (heure_str, heure_str))
            row = c.fetchone()
            if row:
                return row['id'], row['nom_quart']
            return None, "Non défini"

