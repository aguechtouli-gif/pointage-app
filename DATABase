# Gestion des pointages (filtres) – version corrigée avec activite_id
# ------------------------------------------------------------
    def get_pointages_filtres(self, date_debut=None, date_fin=None, matricule=None,
                              type_pointage=None, activite_id=None, division_id=None,
                              direction_id=None, departement_id=None, service_id=None, equipe_id=None,
                              direction_nom=None, departement_nom=None, service_nom=None, equipe_nom=None):
        query = """
            SELECT pt.*,
                   p.matricule, p.nom, p.prenom, p.fonction,
                   dir.nom_direction as direction_nom,
                   dep.nom_departement as departement_nom,
                   s.nom_service as service_nom,
                   e.nom_equipe as equipe_nom
            FROM pointages pt
            JOIN personnel p ON pt.personnel_id = p.id
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE 1=1
        """
        params = []
        if date_debut:
            query += " AND pt.date_pointage >= ?"
            params.append(date_debut)
        if date_fin:
            query += " AND pt.date_pointage <= ?"
            params.append(date_fin)
        if matricule:
            query += " AND p.matricule LIKE ?"
            params.append(f'%{matricule}%')
        if type_pointage:
            query += " AND pt.type_pointage = ?"
            params.append(type_pointage)
        if activite_id:
            query += " AND p.activite_id = ?"
            params.append(activite_id)
        if division_id:
            query += " AND p.division_id = ?"
            params.append(division_id)
        if direction_id:
            query += " AND p.direction_id = ?"
            params.append(direction_id)
        if departement_id:
            query += " AND p.departement_id = ?"
            params.append(departement_id)
        if service_id:
            query += " AND p.service_id = ?"
            params.append(service_id)
        if equipe_id:
            query += " AND p.equipe_id = ?"
            params.append(equipe_id)
        if direction_nom:
            query += " AND dir.nom_direction = ?"
            params.append(direction_nom)
        if departement_nom:
            query += " AND dep.nom_departement = ?"
            params.append(departement_nom)
        if service_nom:
            query += " AND s.nom_service = ?"
            params.append(service_nom)
        if equipe_nom:
            query += " AND e.nom_equipe = ?"
            params.append(equipe_nom)

        query += " ORDER BY pt.date_pointage DESC, pt.heure_pointage DESC"
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query, params)
            return [dict(row) for row in c.fetchall()]

