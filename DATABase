from datetime import datetime, date, timedelta
import pandas as pd


class Database:

    def __init__(self):
        os.makedirs("pointage_data", exist_ok=True)
        self.db_name = os.path.join("pointage_data", "pointage_system.db")
        self.init_database()
        self.verify_and_fix_database()
        self.ajouter_donnees_test()

    def get_connection(self):
        """Retourne une connexion SQLite avec row_factory activé."""
        conn = sqlite3.connect(self.db_name, timeout=30)
        conn.row_factory = sqlite3.Row
        return conn

