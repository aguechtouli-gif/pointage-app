    # ------------------------------------------------------------
    def _calculer_heures_jour(self, pts):
        from datetime import datetime
        entree = None
        sortie = None
        pause_debut = None
        pause_fin = None
        for p in pts:
            if p['type'] == 'entrée':
                entree = datetime.strptime(p['heure'], '%H:%M:%S')
            elif p['type'] == 'sortie':
                sortie = datetime.strptime(p['heure'], '%H:%M:%S')
            elif p['type'] == 'pause_début':
                pause_debut = datetime.strptime(p['heure'], '%H:%M:%S')
            elif p['type'] == 'pause_fin':
                pause_fin = datetime.strptime(p['heure'], '%H:%M:%S')
        if entree and sortie:
            total = (sortie - entree).total_seconds() / 3600
            if pause_debut and pause_fin:
                total -= (pause_fin - pause_debut).total_seconds() / 3600
            return total
        return 0

