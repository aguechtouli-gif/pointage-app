    # Rapport d'absence avec filtres avancés
    #------------------------------------------------------------
    def get_absence_report(self, date_debut, date_fin, search=None, direction_nom=None,
                       departement_nom=None, service_nom=None, equipe_nom=None,
                       type_rapport='resume'):
        from datetime import datetime, timedelta

        debut = datetime.strptime(date_debut, '%Y-%m-%d').date()
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date()

         # Toutes les dates de la période
        # Toutes les dates sous forme de chaîne YYYY-MM-DD
        toutes_dates_str = [(debut + timedelta(days=i)).strftime('%Y-%m-%d') for i in range((fin - debut).days + 1)]
        toutes_dates_obj = [datetime.strptime(d, '%Y-%m-%d').date() for d in toutes_dates_str]
        # Configuration des weekends
        weekend_jours = [5, 6]  # samedi, dimanche
        try:
            weekend_str = self.get_parametre('jours_weekend', '5,6')
            weekend_jours = [int(x.strip()) for x in weekend_str.split(',')]
        except:
            pass

        def est_ouvrable(d):
            return d.weekday() not in weekend_jours

        def est_ferie(d):
            with self.get_connection() as conn:
                c = conn.cursor()
                c.execute("SELECT COUNT(*) FROM jours_feries WHERE date_jour = ?", (d,))
                return c.fetchone()[0] > 0

        # Requête pour les agents (recherche élargie)
        query_agents = """
            SELECT p.id, p.matricule, p.nom, p.prenom, p.badge_id, p.fonction,
                   dir.nom_direction as direction,
                   dep.nom_departement as departement,
                   s.nom_service as service,
                   e.nom_equipe as equipe
            FROM personnel p
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE p.statut = 'actif' AND p.concerne_pointage = 1
        """
        params_agents = []
        if search:
            st = f'%{search}%'
            query_agents += " AND (p.matricule LIKE ? OR p.nom LIKE ? OR p.prenom LIKE ? OR p.badge_id LIKE ?)"
            params_agents.extend([st, st, st, st])
        if direction_nom and direction_nom not in ('', 'Toutes'):
            query_agents += " AND dir.nom_direction = ?"
            params_agents.append(direction_nom)
        if departement_nom and departement_nom not in ('', 'Tous'):
            query_agents += " AND dep.nom_departement = ?"
            params_agents.append(departement_nom)
        if service_nom and service_nom not in ('', 'Tous'):
            query_agents += " AND s.nom_service = ?"
            params_agents.append(service_nom)
        if equipe_nom and equipe_nom not in ('', 'Toutes'):
            query_agents += " AND e.nom_equipe = ?"
            params_agents.append(equipe_nom)

        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params_agents)
            agents = c.fetchall()

            if type_rapport == 'resume':
                resultats = []
                for agent in agents:
                    # Jours ouvrés de la période (exclut weekends et fériés)
                    jours_ouvrables = sum(1 for d in toutes_dates_obj if est_ouvrable(d) and not est_ferie(d))

                    # Jours de présence (pointages distincts)
                    c.execute("""
                        SELECT COUNT(DISTINCT date_pointage) as jours
                        FROM pointages
                        WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                    """, (agent['id'], debut, fin))
                    nb_presences = c.fetchone()[0] or 0

                    # Jours de congés (périodes validées)
                    c.execute("""
                        SELECT SUM(
                            julianday(MIN(date_fin, ?)) - julianday(MAX(date_debut, ?)) + 1
                        ) as total
                        FROM conges
                        WHERE personnel_id = ? AND statut = 'approuve'
                            AND date_debut <= ? AND date_fin >= ?
                    """, (fin, debut, agent['id'], fin, debut))
                    row = c.fetchone()
                    nb_conges = int(row[0]) if row and row[0] else 0

                    absences = jours_ouvrables - nb_presences - nb_conges
                    if absences < 0:
                        absences = 0

                    resultats.append({
                        'matricule': agent['matricule'],
                        'nom': agent['nom'],
                        'prenom': agent['prenom'],
                        'fonction': agent['fonction'],
                        'direction': agent['direction'] or '',
                        'departement': agent['departement'] or '',
                        'service': agent['service'] or '',
                        'equipe': agent['equipe'] or '',
                        'jours_ouvres': jours_ouvrables,
                        'pointes': nb_presences,
                        'conges': nb_conges,
                        'absences': absences
                    })
                return resultats

            else:  # mode détail
                details = []
                for agent in agents:
                    # Récupérer les dates de présence (pointages)
                    c.execute("""
                        SELECT DISTINCT DATE(date_pointage) as date_presence
                        FROM pointages
                        WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                    """, (agent['id'], debut, fin))
                    presences_str = {row[0] for row in c.fetchall()}

                    # Récupérer les dates de congé
                    conges_str = set()
                    c.execute("""
                        SELECT date_debut, date_fin
                        FROM conges
                        WHERE personnel_id = ? AND statut = 'approuve'
                            AND date_debut <= ? AND date_fin >= ?
                    """, (agent['id'], fin, debut))
                    for row in c.fetchall():
                        d_deb = row[0] 
                        d_fin = row[1] 
                        
                        # Si ce sont des date objects, les convertir en string
                        if not isinstance(d_deb, str):
                            d_deb = d_deb.strftime('%Y-%m-%d')
                        if not isinstance(d_fin, str):
                            d_fin = d_fin.strftime('%Y-%m-%d')
                        d = datetime.strptime(d_deb, '%Y-%m-%d').date()
                        d_end = datetime.strptime(d_fin, '%Y-%m-%d').date()
                        while d <= d_end:
                            conges_str.add(d.strftime('%Y-%m-%d'))
                            d += timedelta(days=1)
                    # Parcourir chaque jour ouvrable
                    for d_str in toutes_dates_str:
                        d_obj = datetime.strptime(d_str, '%Y-%m-%d').date()
                        if not est_ouvrable(d_obj) or est_ferie(d_obj):
                            continue
                        if d_str not in presences_str and d_str not in conges_str:
                            details.append({
                                'date': d_str,
                                'matricule': agent['matricule'],
                                'nom': agent['nom'],
                                'prenom': agent['prenom'],
                                'direction': agent['direction'] or '',
                                'departement': agent['departement'] or '',
                                'service': agent['service'] or '',
                                'equipe': agent['equipe'] or '',
                                'type_absence': 'Absence injustifiée'
                            })
                return details
    #------------------------------------------------------------
