    def get_retards_cumules_par_jour(self, date_debut, date_fin, direction_nom=None,
                                  departement_nom=None, service_nom=None, equipe_nom=None):
        """Retourne les statistiques de retards cumulés par jour pour la période"""
        from datetime import datetime, timedelta
    
        debut = datetime.strptime(date_debut, '%Y-%m-%d').date() if isinstance(date_debut, str) else date_debut
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date() if isinstance(date_fin, str) else date_fin
    
        # Requête de base
        query = """
            SELECT 
                rc.date_retard as date,
                p.matricule,
                p.nom,
                p.prenom,
                dir.nom_direction as direction,
                dep.nom_departement as departement,
                s.nom_service as service,
                e.nom_equipe as equipe,
                COUNT(rc.id) as nb_retards,
                SUM(rc.minutes_retard) as total_minutes,
                SUM(CASE WHEN rc.est_justifie = 1 THEN rc.minutes_retard ELSE 0 END) as minutes_justifiees,
                SUM(CASE WHEN rc.est_justifie = 0 THEN rc.minutes_retard ELSE 0 END) as minutes_non_justifiees
            FROM retards_cumules rc
            JOIN personnel p ON rc.personnel_id = p.id
            LEFT JOIN directions dir ON p.direction_id = dir.id
            LEFT JOIN departements dep ON p.departement_id = dep.id
            LEFT JOIN services s ON p.service_id = s.id
            LEFT JOIN equipes e ON p.equipe_id = e.id
            WHERE rc.date_retard BETWEEN ? AND ?
        """
        params = [debut, fin]
    
        if direction_nom and direction_nom not in ('Toutes', ''):
            query += " AND dir.nom_direction = ?"
            params.append(direction_nom)
        if departement_nom and departement_nom not in ('Tous', ''):
            query += " AND dep.nom_departement = ?"
            params.append(departement_nom)
        if service_nom and service_nom not in ('Tous', ''):
            query += " AND s.nom_service = ?"
            params.append(service_nom)
        if equipe_nom and equipe_nom not in ('Toutes', ''):
            query += " AND e.nom_equipe = ?"
            params.append(equipe_nom)
    
        query += " GROUP BY rc.date_retard, p.id ORDER BY rc.date_retard DESC, p.nom, p.prenom"
    
        with self.get_connection() as conn:
            c = conn.cursor()
            c.execute(query, params)
            rows = c.fetchall()
        
            resultats = []
            for row in rows:
                resultats.append({
                    'date': row['date'],
                    'matricule': row['matricule'],
                    'nom': row['nom'],
                    'prenom': row['prenom'],
                    'direction': row['direction'] or '',
                    'departement': row['departement'] or '',
                    'service': row['service'] or '',
                    'equipe': row['equipe'] or '',
                    'nb_retards': row['nb_retards'] or 0,
                    'total_minutes': row['total_minutes'] or 0,
                    'minutes_justifiees': row['minutes_justifiees'] or 0,
                    'minutes_non_justifiees': row['minutes_non_justifiees'] or 0
                })
            return resultats

