@app.route('/rapports/absences', methods=['GET', 'POST'])
@login_required
def rapport_absences():
    if request.method == 'POST':
        date_debut = request.form['date_debut']
        date_fin = request.form['date_fin']
        matricule = request.form.get('matricule', '').strip()
        direction = request.form.get('direction')
        departement = request.form.get('departement')
        service = request.form.get('service')
        equipe = request.form.get('equipe')

        # Construire la requête pour récupérer les agents correspondant
        query_agents = "SELECT id, matricule, nom, prenom FROM personnel WHERE statut='actif'"
        params = []
        if matricule:
            query_agents += " AND matricule LIKE ?"
            params.append(f'%{matricule}%')
        if direction and direction != 'Toutes':
            query_agents += " AND direction = ?"
            params.append(direction)
        if departement and departement != 'Tous':
            query_agents += " AND departement = ?"
            params.append(departement)
        if service and service != 'Tous':
            query_agents += " AND service = ?"
            params.append(service)
        if equipe and equipe != 'Toutes':
            query_agents += " AND equipe = ?"
            params.append(equipe)

        with db.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params)
            agents = c.fetchall()

        resultats = []
        debut = datetime.strptime(date_debut, '%Y-%m-%d').date()
        fin = datetime.strptime(date_fin, '%Y-%m-%d').date()

        for agent in agents:
            jours_ouvres_list = list(jours_ouvres(debut, fin))
            nb_jours_ouvres = len(jours_ouvres_list)

            c.execute("""
                SELECT COUNT(DISTINCT date_pointage)
                FROM pointages
                WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
            """, (agent['id'], debut, fin))
            nb_pointes = c.fetchone()[0] or 0

            c.execute("""
                SELECT SUM(
                    julianday(MIN(date_fin, ?)) - julianday(MAX(date_debut, ?)) + 1
                )
                FROM conges
                WHERE personnel_id = ? AND statut = 'approuve'
                  AND date_debut <= ? AND date_fin >= ?
            """, (fin, debut, agent['id'], fin, debut))
            nb_conges = c.fetchone()[0] or 0
            nb_conges = int(round(nb_conges))

            absences = nb_jours_ouvres - nb_pointes - nb_conges
            if absences < 0:
                absences = 0

            resultats.append({
                'matricule': agent['matricule'],
                'nom': agent['nom'],
                'prenom': agent['prenom'],
                'jours_ouvres': nb_jours_ouvres,
                'pointes': nb_pointes,
                'conges': nb_conges,
                'absences': absences
            })

        return render_template('rapports/absences_resultats.html',
                               resultats=resultats,
                               date_debut=date_debut,
                               date_fin=date_fin)

    # GET : afficher formulaire avec listes
    directions = db.get_all_directions()
    # Récupérer listes distinctes pour départements, services, équipes
    with db.get_connection() as conn:
        c = conn.cursor()
        c.execute("SELECT DISTINCT departement FROM personnel WHERE departement IS NOT NULL ORDER BY departement")
        departements = [r[0] for r in c.fetchall()]
        c.execute("SELECT DISTINCT service FROM personnel WHERE service IS NOT NULL ORDER BY service")
        services = [r[0] for r in c.fetchall()]
        c.execute("SELECT DISTINCT equipe FROM personnel WHERE equipe IS NOT NULL ORDER BY equipe")
        equipes = [r[0] for r in c.fetchall()]
    return render_template('rapports/absences_filtres.html',
                           directions=directions,
                           departements=departements,
                           services=services,
                           equipes=equipes)

