# Rapports
# -------------------------------------------------------------------
def est_weekend(date_obj):
    # Fonction utilitaire à utiliser dans les rapports si besoin
    jours_str = db.get_parametre('jours_weekend', '5,6')
    jours_weekend = [int(x.strip()) for x in jours_str.split(',') if x.strip()]
    return date_obj.weekday() in jours_weekend

def est_jour_ferie(date_obj):
    with db.get_connection() as conn:
        c = conn.cursor()
        c.execute("SELECT COUNT(*) FROM jours_feries WHERE date_jour=?", (date_obj,))
        return c.fetchone()[0] > 0

def jours_ouvres(debut, fin):
    jour = debut
    while jour <= fin:
        if not est_weekend(jour) and not est_jour_ferie(jour):
            yield jour
        jour += timedelta(days=1)

