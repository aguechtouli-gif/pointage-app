@app.route('/rapports/pdf', methods=['POST'])
@login_required
def exporter_rapport_pdf():
    from reportlab.lib.pagesizes import A4, landscape
    from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer, Image
    from reportlab.lib import colors
    from reportlab.lib.units import cm
    import json, os, tempfile

    data = request.get_json()
    titre = data.get('titre', 'Rapport')
    colonnes = data.get('colonnes', [])
    lignes = data.get('lignes', [])
    sous_titre = data.get('sous_titre', '')
    if not lignes:
        return jsonify({'success': False, 'message': 'Aucune donnée'}), 400
    pagesize = landscape(A4) if len(colonnes) > 6 else A4
    with tempfile.NamedTemporaryFile(delete=False, suffix='.pdf') as tmp:
        pdf_path = tmp.name
    doc = SimpleDocTemplate(pdf_path, pagesize=pagesize,
                            rightMargin=1.5*cm, leftMargin=1.5*cm,
                            topMargin=2*cm, bottomMargin=2*cm)
    styles = get_pdf_styles()
    elements = []
    logo_path = os.path.join('static', 'images', 'logo.png')
    if os.path.exists(logo_path):
        logo = Image(logo_path, width=3*cm, height=3*cm)
        elements.append(logo)
        elements.append(Spacer(1, 0.5*cm))
    elements.append(Paragraph(titre, styles['CustomTitle']))
    if sous_titre:
        elements.append(Paragraph(sous_titre, styles['Normal']))
    elements.append(Spacer(1, 0.5*cm))
    data_table = [colonnes] + lignes
    table = Table(data_table, repeatRows=1, hAlign='CENTER')
    style = TableStyle([
        ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#3498db')),
        ('TEXTCOLOR', (0,0), (-1,0), colors.white),
        ('ALIGN', (0,0), (-1,-1), 'CENTER'),
        ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
        ('FONTSIZE', (0,0), (-1,0), 11),
        ('BOTTOMPADDING', (0,0), (-1,0), 10),
        ('BACKGROUND', (0,1), (-1,-1), colors.HexColor('#f8f9fa')),
        ('GRID', (0,0), (-1,-1), 0.5, colors.grey),
        ('FONTSIZE', (0,1), (-1,-1), 9),
        ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
    ])
    for i, col in enumerate(colonnes):
        if any(k in col.lower() for k in ('min', '€', 'id', 'nb', 'total', 'pénalité', 'jours')):
            style.add('ALIGN', (i,1), (i,-1), 'RIGHT')
        else:
            style.add('ALIGN', (i,1), (i,-1), 'LEFT')
    table.setStyle(style)
    elements.append(table)
    from datetime import datetime
    user = session.get('prenom', '') + ' ' + session.get('nom', '')
    def add_footer(canvas, doc):
        canvas.saveState()
        footer = f"Généré le {datetime.now().strftime('%d/%m/%Y %H:%M')} par {user} - Page {doc.page}"
        canvas.setFont('Helvetica', 8)
        canvas.drawCentredString(doc.pagesize[0]/2, 1.2*cm, footer)
        canvas.restoreState()
    doc.build(elements, onFirstPage=add_footer, onLaterPages=add_footer)
    return send_file(pdf_path, as_attachment=False, download_name="rapport.pdf")


@app.route('/rapports/retards/export_pdf', methods=['POST'])
@login_required
def exporter_retards_pdf():
    # Récupérer les filtres depuis le formulaire POST
    date_debut = request.form.get('date_debut')
    date_fin = request.form.get('date_fin')
    matricule = request.form.get('matricule', '').strip()
    direction = request.form.get('direction')
    departement = request.form.get('departement')
    service = request.form.get('service')
    equipe = request.form.get('equipe')
    type_rapport = request.form.get('type_rapport', 'resume')
    
    # Valeurs par défaut si vides
    if not date_debut:
        date_debut = date.today().replace(day=1).strftime('%Y-%m-%d')
    if not date_fin:
        date_fin = date.today().strftime('%Y-%m-%d')
    
    # Récupérer TOUTES les données (sans pagination)
    if type_rapport == 'resume':
        resultats = db.get_retard_report(
            date_debut=date_debut, date_fin=date_fin,
            matricule=matricule,
            direction_nom=direction if direction else None,
            departement_nom=departement if departement else None,
            service_nom=service if service else None,
            equipe_nom=equipe if equipe else None,
            type_rapport='resume'
        )
        if not resultats:
            flash("Aucune donnée à exporter", "warning")
            return redirect(url_for('rapport_retards'))
        
        df = pd.DataFrame(resultats)
        # Renommer les colonnes
        colonnes = ['matricule', 'nom', 'prenom', 'direction', 'nb_retards', 'total_min_retard', 'nb_departs_anticipes', 'total_min_anticipe', 'penalite']
        df = df[colonnes]
        df.columns = ['Matricule', 'Nom', 'Prénom', 'Direction', 'Nb retards', 'Total min retard', 'Nb départs anticipés', 'Total min anticipé', 'Pénalité (€)']
        titre = f"Rapport des retards - Résumé du {date_debut} au {date_fin}"
        orientation = 'landscape' if len(df) > 10 else 'portrait'
    else:
        details = db.get_retard_report(
            date_debut=date_debut, date_fin=date_fin,
            matricule=matricule,
            direction_nom=direction if direction else None,
            departement_nom=departement if departement else None,
            service_nom=service if service else None,
            equipe_nom=equipe if equipe else None,
            type_rapport='detail'
        )
        if not details:
            flash("Aucune donnée à exporter", "warning")
            return redirect(url_for('rapport_retards'))
        
        df = pd.DataFrame(details)
        colonnes = ['date', 'heure', 'type', 'matricule', 'nom', 'prenom', 'minutes', 'direction', 'departement', 'service', 'equipe']
        df = df[colonnes]
        df.columns = ['Date', 'Heure', 'Type', 'Matricule', 'Nom', 'Prénom', 'Minutes', 'Direction', 'Département', 'Service', 'Équipe']
        titre = f"Rapport des retards - Détail du {date_debut} au {date_fin}"
        orientation = 'landscape' if len(df) > 15 else 'portrait'
    
    # Générer le PDF
    import tempfile
    with tempfile.NamedTemporaryFile(delete=False, suffix='.pdf') as tmp:
        pdf_path = tmp.name
    dataframe_to_pdf(df, titre, pdf_path, orientation=orientation)
    
    with open(pdf_path, 'rb') as f:
        pdf_data = f.read()
    os.unlink(pdf_path)
    
    response = make_response(pdf_data)
    response.headers['Content-Type'] = 'application/pdf'
    response.headers['Content-Disposition'] = f'attachment; filename=rapport_retards_{datetime.now().strftime("%Y%m%d_%H%M%S")}.pdf'
    return response

def get_pdf_styles():
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.lib import colors
    styles = getSampleStyleSheet()
    styles.add(ParagraphStyle(name='CustomTitle',
                              parent=styles['Title'],
                              fontSize=16,
                              textColor=colors.HexColor('#2c3e50'),
                              alignment=1,
                              spaceAfter=20))
    return styles

