    direction_id = request.args.get('direction_id', '')
    departement_id = request.args.get('departement_id', '')
    service_id = request.args.get('service_id', '')
    equipe_id = request.args.get('equipe_id', '')

    pointages = db.get_pointages_filtres(
        date_debut=date_debut,
        date_fin=date_fin,
        matricule=matricule,
        activite_id=activite_id,
        division_id=division_id,
        direction_id=direction_id,
        departement_id=departement_id,
        service_id=service_id,
        equipe_id=equipe_id
    )

    with db.get_connection() as conn:
        c = conn.cursor()
        c.execute("SELECT id, nom_activite FROM activites WHERE active = 1 ORDER BY nom_activite")
        activites = [{'id': r[0], 'nom': r[1]} for r in c.fetchall()]
        c.execute("SELECT id, nom_division FROM divisions WHERE active = 1 ORDER BY nom_division")
        divisions = [{'id': r[0], 'nom': r[1]} for r in c.fetchall()]
        c.execute("SELECT id, nom_direction FROM directions WHERE active = 1 ORDER BY nom_direction")
        directions = [{'id': r[0], 'nom': r[1]} for r in c.fetchall()]
        c.execute("SELECT id, nom_departement FROM departements WHERE active = 1 ORDER BY nom_departement")
        departements = [{'id': r[0], 'nom': r[1]} for r in c.fetchall()]
        c.execute("SELECT id, nom_service FROM services WHERE active = 1 ORDER BY nom_service")
        services = [{'id': r[0], 'nom': r[1]} for r in c.fetchall()]
        c.execute("SELECT id, nom_equipe FROM equipes WHERE active = 1 ORDER BY nom_equipe")
        equipes = [{'id': r[0], 'nom': r[1]} for r in c.fetchall()]

    return render_template('pointages/liste.html',
                           pointages=pointages,
                           date_debut=date_debut,
                           date_fin=date_fin,
                           matricule=matricule,
                           activites=activites,
                           divisions=divisions,
                           directions=directions,
                           departements=departements,
                           services=services,
                           equipes=equipes,
                           activite_id=activite_id,
                           division_id=division_id,
                           direction_id=direction_id,
                           departement_id=departement_id,
                           service_id=service_id,
                           equipe_id=equipe_id)

@app.route('/pointages/rapide', methods=['GET', 'POST'])
@login_required
def pointage_rapide():
    if request.method == 'POST':
        identifiant = request.form['identifiant'].strip()
        type_pt = request.form['type_pointage']
        pers = db.get_personnel_by_matricule(identifiant) or db.get_personnel_by_badge(identifiant)
        if not pers:
            flash("Personnel non trouvé.", "danger")
        else:
            pid, msg = db.add_pointage_avance(
                matricule=pers['matricule'],
                type_pointage=type_pt,
                mode='web',
                user_id=session['user_id']
            )
            if pid:
                flash(f"Pointage enregistré pour {pers['prenom']} {pers['nom']} - {msg}", "success")
            else:
                flash(f"Erreur : {msg}", "danger")
        return redirect(url_for('pointage_rapide'))
    return render_template('pointages/rapide.html')

@app.route('/pointages/importer', methods=['GET', 'POST'])
@login_required
@admin_required
def importer_pointages():
    if request.method == 'POST':
        fichier = request.files['fichier']
        if fichier and fichier.filename.endswith(('.csv', '.xlsx', '.xls')):
            filename = secure_filename(fichier.filename)
            filepath = os.path.join(app.config['UPLOAD_FOLDER'], filename)
            fichier.save(filepath)
            mapping = {}
            resultats = db.import_pointages_from_file(filepath, format_colonnes=mapping, user_id=session['user_id'])
            flash(f"Import : {resultats['importes']} créés, {resultats['doublons']} doublons, {resultats['erreurs']} erreurs.", "info")
            if resultats['details']:
                for detail in resultats['details'][:20]:
                    flash(detail, "warning")
            return redirect(url_for('liste_pointages'))
        else:
            flash("Format de fichier non supporté. Utilisez CSV ou Excel.", "danger")
    return render_template('pointages/import.html')

