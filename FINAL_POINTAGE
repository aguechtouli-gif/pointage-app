# ============================================================
# Fonction utilitaire pour convertir une heure en minutes
# ============================================================
def heure_en_minutes(heure_str):
    try:
        parts = heure_str.split(':')
        h = int(parts[0])
        m = int(parts[1])
        s = int(parts[2]) if len(parts) > 2 else 0
        return h * 60 + m + s / 60
    except:
        return 0

