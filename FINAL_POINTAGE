    with db.get_connection() as conn:
        c = conn.cursor()
        c.execute("SELECT DISTINCT departement FROM personnel WHERE departement IS NOT NULL ORDER BY departement")
        departements = [r[0] for r in c.fetchall()]
        c.execute("SELECT DISTINCT service FROM personnel WHERE service IS NOT NULL ORDER BY service")
        services = [r[0] for r in c.fetchall()]
        c.execute("SELECT DISTINCT equipe FROM personnel WHERE equipe IS NOT NULL ORDER BY equipe")
        equipes = [r[0] for r in c.fetchall()]
    return render_template('rapports/retards_filtres.html',
                           directions=directions,
                           departements=departements,
                           services=services,
                           equipes=equipes)

# Export PDF générique (à utiliser pour les rapports)
@app.route('/rapports/pdf', methods=['POST'])
@login_required
def exporter_rapport_pdf():
    from reportlab.lib.pagesizes import A4, landscape
    from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer
    from reportlab.lib.styles import getSampleStyleSheet
    from reportlab.lib import colors
    from reportlab.lib.units import cm
    import json

    data = request.get_json()
    titre = data.get('titre', 'Rapport')
    colonnes = data.get('colonnes', [])
    lignes = data.get('lignes', [])

    if not lignes:
        return jsonify({'success': False, 'message': 'Aucune donnée'}), 400

    # Créer un PDF temporaire
    with tempfile.NamedTemporaryFile(delete=False, suffix='.pdf') as tmp:
        pdf_path = tmp.name

    doc = SimpleDocTemplate(pdf_path, pagesize=landscape(A4) if len(colonnes) > 6 else A4,
                            rightMargin=2*cm, leftMargin=2*cm,
                            topMargin=2*cm, bottomMargin=2*cm)

    elements = []

    # Titre
    styles = getSampleStyleSheet()
    elements.append(Paragraph(titre, styles['Title']))
    elements.append(Spacer(1, 0.5*cm))

    # Tableau
    data_table = [colonnes] + lignes
    table = Table(data_table, repeatRows=1)
    style = TableStyle([
        ('BACKGROUND', (0,0), (-1,0), colors.grey),
        ('TEXTCOLOR', (0,0), (-1,0), colors.whitesmoke),
        ('ALIGN', (0,0), (-1,-1), 'CENTER'),
        ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
        ('FONTSIZE', (0,0), (-1,0), 12),
        ('BOTTOMPADDING', (0,0), (-1,0), 12),
        ('BACKGROUND', (0,1), (-1,-1), colors.beige),
        ('GRID', (0,0), (-1,-1), 1, colors.black),
        ('FONTSIZE', (0,1), (-1,-1), 10),
    ])
    table.setStyle(style)
    elements.append(table)

    # Pied de page
    from datetime import datetime
    user = session.get('prenom', '') + ' ' + session.get('nom', '')
    def add_footer(canvas, doc):
        canvas.saveState()
        footer = f"Généré le {datetime.now().strftime('%d/%m/%Y %H:%M')} par {user}"
        canvas.setFont('Helvetica', 8)
        canvas.drawCentredString(doc.pagesize[0]/2, 1.5*cm, footer)
        canvas.restoreState()

    doc.build(elements, onFirstPage=add_footer, onLaterPages=add_footer)

    return send_file(pdf_path, as_attachment=False, download_name="rapport.pdf")
