@app.route('/pointages')
@login_required
def liste_pointages():
    # Récupération des paramètres de pagination
    page = request.args.get('page', 1, type=int)
    per_page = request.args.get('per_page', 20, type=int)

    # Récupération des filtres
    date_debut = request.args.get('date_debut', '')
    date_fin = request.args.get('date_fin', '')
    matricule = request.args.get('matricule', '')
    activite_id = request.args.get('activite_id', type=int)
    division_id = request.args.get('division_id', type=int)
    direction_id = request.args.get('direction_id', type=int)
    departement_id = request.args.get('departement_id', type=int)
    service_id = request.args.get('service_id', type=int)
    equipe_id = request.args.get('equipe_id', type=int)

    # Construction de la requête SQL
    query = """
        SELECT pt.id, pt.date_pointage, pt.heure_pointage, pt.type_pointage, pt.mode,
               p.matricule, p.nom, p.prenom, p.fonction,
               u.username as utilisateur
        FROM pointages pt
        JOIN personnel p ON pt.personnel_id = p.id
        LEFT JOIN utilisateurs u ON pt.user_id = u.id
        WHERE 1=1
    """
    params = []

    if date_debut:
        query += " AND pt.date_pointage >= ?"
        params.append(date_debut)
    if date_fin:
        query += " AND pt.date_pointage <= ?"
        params.append(date_fin)
    if matricule:
        query += " AND p.matricule LIKE ?"
        params.append(f'%{matricule}%')
    if activite_id:
        query += " AND p.activite_id = ?"
        params.append(activite_id)
    if division_id:
        query += " AND p.division_id = ?"
        params.append(division_id)
    if direction_id:
        query += " AND p.direction_id = ?"
        params.append(direction_id)
    if departement_id:
        query += " AND p.departement_id = ?"
        params.append(departement_id)
    if service_id:
        query += " AND p.service_id = ?"
        params.append(service_id)
    if equipe_id:
        query += " AND p.equipe_id = ?"
        params.append(equipe_id)

    # Compter le nombre total d'enregistrements
    count_query = f"SELECT COUNT(*) FROM ({query}) AS sub"
    with db.get_connection() as conn:
        cursor = conn.cursor()
        cursor.execute(count_query, params)
        total = cursor.fetchone()[0]

    total_pages = (total + per_page - 1) // per_page if total > 0 else 1

    # Pagination
    offset = (page - 1) * per_page
    query += " ORDER BY pt.date_pointage DESC, pt.heure_pointage DESC LIMIT ? OFFSET ?"
    params_pag = params + [per_page, offset]
    cursor.execute(query, params_pag)
    pointages = [dict(row) for row in cursor.fetchall()]

    # Récupération des listes pour les filtres
    activites = db.get_all_activites()
    divisions = db.get_all_divisions()
    directions = db.get_all_directions()
    departements = db.get_all_departements()
    services = db.get_all_services()
    equipes = db.get_all_equipes()

    # Construction du dictionnaire des filtres pour la pagination (exclut page et per_page)
    filter_args = {
        'date_debut': date_debut,
        'date_fin': date_fin,
        'matricule': matricule,
        'activite_id': activite_id,
        'division_id': division_id,
        'direction_id': direction_id,
        'departement_id': departement_id,
        'service_id': service_id,
        'equipe_id': equipe_id
    }
    filter_args = {k: v for k, v in filter_args.items() if v}

    return render_template('pointages/liste.html',
                           pointages=pointages,
                           page=page,
                           total_pages=total_pages,
                           per_page=per_page,
                           filter_args=filter_args,
                           date_debut=date_debut,
                           date_fin=date_fin,
                           matricule=matricule,
                           activite_id=activite_id,
                           division_id=division_id,
                           direction_id=direction_id,
                           departement_id=departement_id,
                           service_id=service_id,
                           equipe_id=equipe_id,
                           activites=activites,
                           divisions=divisions,
                           directions=directions,
                           departements=departements,
                           services=services,
                           equipes=equipes)
