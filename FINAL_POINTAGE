        matricule = request.form.get('matricule', '').strip()
        direction = request.form.get('direction')
        departement = request.form.get('departement')
        service = request.form.get('service')
        equipe = request.form.get('equipe')

        # Construire la requête pour récupérer les agents
        query_agents = "SELECT id, matricule, nom, prenom FROM personnel WHERE statut='actif'"
        params_agents = []
        if matricule:
            query_agents += " AND matricule LIKE ?"
            params_agents.append(f'%{matricule}%')
        if direction and direction != 'Toutes':
            query_agents += " AND direction = ?"
            params_agents.append(direction)
        if departement and departement != 'Tous':
            query_agents += " AND departement = ?"
            params_agents.append(departement)
        if service and service != 'Tous':
            query_agents += " AND service = ?"
            params_agents.append(service)
        if equipe and equipe != 'Toutes':
            query_agents += " AND equipe = ?"
            params_agents.append(equipe)

        with db.get_connection() as conn:
            c = conn.cursor()
            c.execute(query_agents, params_agents)
            agents = c.fetchall()

        if not agents:
            flash("Aucun agent ne correspond aux filtres.", "info")
            return redirect(url_for('rapport_retards'))

        penalite_par_min = float(db.get_parametre('penalite_retard', '0.50'))
        resultats = []

        for agent in agents:
            c.execute("""
                SELECT COUNT(id) as nb_retards,
                       COALESCE(SUM(minutes_retard), 0) as total_min,
                       COALESCE(SUM(CASE WHEN est_justifie=1 THEN minutes_retard ELSE 0 END), 0) as justifie,
                       COALESCE(SUM(CASE WHEN est_justifie=0 THEN minutes_retard ELSE 0 END), 0) as non_justifie
                FROM retards_cumules
                WHERE personnel_id = ? AND date_retard BETWEEN ? AND ?
            """, (agent['id'], date_debut, date_fin))
            row = c.fetchone()
            nb_retards = row['nb_retards'] or 0
            total_min = row['total_min'] or 0
            justifie = row['justifie'] or 0
            non_justifie = row['non_justifie'] or 0
            penalite = non_justifie * penalite_par_min

            resultats.append({
                'matricule': agent['matricule'],
                'nom': agent['nom'],
                'prenom': agent['prenom'],
                'nb_retards': nb_retards,
                'total_min': total_min,
                'justifie': justifie,
                'non_justifie': non_justifie,
                'penalite': penalite
            })

        resultats.sort(key=lambda x: x['total_min'], reverse=True)
        return render_template('rapports/retards_resultats.html',
                               resultats=resultats,
                               date_debut=date_debut,
                               date_fin=date_fin)

    # GET
