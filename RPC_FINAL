@app.route('/rapports/presence', methods=['GET', 'POST'])
@login_required
def rapport_presence():
    if request.method == 'POST':
        date_debut = request.form['date_debut']
        date_fin = request.form['date_fin']
        direction = request.form.get('direction', '')
        departement = request.form.get('departement', '')
        service = request.form.get('service', '')
        equipe = request.form.get('equipe', '')
        matricule = request.form.get('matricule', '').strip()
        type_rapport = request.form.get('type_rapport', 'resume')

        if type_rapport == 'resume':
            # Utiliser directement la méthode qui filtre et compte les présences
            resultats = db.get_presence_report(
                date_debut=date_debut,
                date_fin=date_fin,
                direction=direction,
                departement=departement,
                service=service,
                equipe=equipe,
                matricule=matricule
            )
            # Renommer la clé 'jours_presence' en 'nb_presences' pour le template
            for r in resultats:
                r['nb_presences'] = r.pop('jours_presence')
            return render_template('rapports/presence_resultats_resume.html',
                                   resultats=resultats,
                                   date_debut=date_debut,
                                   date_fin=date_fin)
        else:
            # Version détaillée : récupérer les agents avec tous les filtres
            with db.get_connection() as conn:
                c = conn.cursor()
                query = """
                    SELECT id, matricule, nom, prenom
                    FROM personnel
                    WHERE statut = 'actif'
                """
                params = []
                if direction and direction != 'Toutes':
                    query += " AND direction = ?"
                    params.append(direction)
                if departement and departement != 'Tous':
                    query += " AND departement = ?"
                    params.append(departement)
                if service and service != 'Tous':
                    query += " AND service = ?"
                    params.append(service)
                if equipe and equipe != 'Toutes':
                    query += " AND equipe = ?"
                    params.append(equipe)
                if matricule:
                    query += " AND matricule LIKE ?"
                    params.append(f'%{matricule}%')
                c.execute(query, params)
                agents = c.fetchall()

            pointages = []
            for agent in agents:
                c.execute("""
                    SELECT date_pointage, heure_pointage, type_pointage
                    FROM pointages
                    WHERE personnel_id = ? AND date_pointage BETWEEN ? AND ?
                    ORDER BY date_pointage, heure_pointage
                """, (agent['id'], date_debut, date_fin))
                for row in c.fetchall():
                    pointages.append({
                        'matricule': agent['matricule'],
                        'nom': agent['nom'],
                        'prenom': agent['prenom'],
