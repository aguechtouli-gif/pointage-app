@app.route('/rapports/retards', methods=['GET', 'POST'])
@login_required
def rapport_retards():
    if request.method == 'POST':
        # ---------- Récupération des paramètres du formulaire ----------
        date_debut = request.form['date_debut']
        date_fin = request.form['date_fin']
        matricule = request.form.get('matricule', '').strip()
        direction = request.form.get('direction')
        departement = request.form.get('departement')
        service = request.form.get('service')
        equipe = request.form.get('equipe')
        type_rapport = request.form.get('type_rapport', 'resume')
        utiliser_globaux = request.form.get('utiliser_horaires_globaux') == 'on'

        # ---------- Paramètres globaux (si demandé) ----------
        if utiliser_globaux:
            heure_entree_globale = db.get_parametre('heure_entree_globale', '08:00:00')
            tolerance_globale = int(db.get_parametre('tolerance_retard_globale', '0'))
        else:
            heure_entree_globale = None
            tolerance_globale = 0

        # ---------- Construction de la requête (pointages d'entrée) ----------
        query = """
            SELECT
                p.id AS personnel_id,
                p.matricule,
                p.nom,
                p.prenom,
                p.heure_entree_theorique,
                p.tolerance_entree,
                pt.date_pointage,
                pt.heure_pointage
            FROM pointages pt
            JOIN personnel p ON pt.personnel_id = p.id
            WHERE p.statut = 'actif'
              AND pt.date_pointage BETWEEN ? AND ?
              AND pt.type_pointage = 'entrée'
        """
        params = [date_debut, date_fin]

        # Ajout des filtres
        if matricule:
            query += " AND p.matricule LIKE ?"
            params.append(f'%{matricule}%')
        if direction and direction != 'Toutes':
            query += " AND p.direction = ?"
            params.append(direction)
        if departement and departement != 'Tous':
            query += " AND p.departement = ?"
            params.append(departement)
        if service and service != 'Tous':
            query += " AND p.service = ?"
            params.append(service)
        if equipe and equipe != 'Toutes':
            query += " AND p.equipe = ?"
            params.append(equipe)

        # ---------- Exécution de la requête ----------
        with db.get_connection() as conn:
            c = conn.cursor()
            c.execute(query, params)
            rows = c.fetchall()

        if not rows:
            flash("Aucun pointage trouvé pour cette période.", "info")
            return redirect(url_for('rapport_retards'))

        penalite_par_min = float(db.get_parametre('penalite_retard', '0.50'))

        # ========== RAPPORT RÉSUMÉ ==========
        if type_rapport == 'resume':
            resume = {}
            for row in rows:
                pid = row['personnel_id']
                if pid not in resume:
                    resume[pid] = {
                        'matricule': row['matricule'],
                        'nom': row['nom'],
                        'prenom': row['prenom'],
                        'nb_retards': 0,
                        'total_min': 0,
                        'justifie': 0,
                        'non_justifie': 0,
                        'penalite': 0.0
                    }

                # Déterminer l'heure théorique et la tolérance selon l'option
                if utiliser_globaux:
                    heure_theorique = heure_entree_globale
                    tolerance = tolerance_globale
                else:
                    heure_theorique = row['heure_entree_theorique']
                    tolerance = row['tolerance_entree']

                # Calcul du retard brut et application de la tolérance
                minutes_pt = heure_en_minutes(row['heure_pointage'])
                minutes_th = heure_en_minutes(heure_theorique)
                retard_brut = minutes_pt - minutes_th

                if retard_brut > tolerance:
                    retard = retard_brut
                    resume[pid]['nb_retards'] += 1
                    resume[pid]['total_min'] += retard
                    resume[pid]['non_justifie'] += retard
                    resume[pid]['penalite'] += retard * penalite_par_min

            resultats = list(resume.values())
            resultats.sort(key=lambda x: x['total_min'], reverse=True)
            return render_template('rapports/retards_resultats_resume.html',
                                   resultats=resultats,
                                   date_debut=date_debut,
                                   date_fin=date_fin)

        # ========== RAPPORT DÉTAILLÉ ==========
        else:
            details = []
            for row in rows:
                if utiliser_globaux:
                    heure_theorique = heure_entree_globale
                    tolerance = tolerance_globale
                else:
                    heure_theorique = row['heure_entree_theorique']
                    tolerance = row['tolerance_entree']

                minutes_pt = heure_en_minutes(row['heure_pointage'])
                minutes_th = heure_en_minutes(heure_theorique)
                retard_brut = minutes_pt - minutes_th

                if retard_brut > tolerance:
                    retard = retard_brut
                    details.append({
                        'matricule': row['matricule'],
                        'nom': row['nom'],
                        'prenom': row['prenom'],
                        'date': row['date_pointage'],
                        'heure': row['heure_pointage'],
                        'minutes': round(retard, 2),
                        'justifie': 'Non',
                        'motif': '',
                        'penalite': round(retard * penalite_par_min, 2)
                    })

            details.sort(key=lambda x: (x['date'], x['heure']))
            return render_template('rapports/retards_resultats_detail.html',
                                   details=details,
                                   date_debut=date_debut,
                                   date_fin=date_fin)

    # ---------- GET : afficher le formulaire ----------
    with db.get_connection() as conn:
        c = conn.cursor()
        # Récupérer les directions distinctes depuis la table personnel
        c.execute("SELECT DISTINCT direction FROM personnel WHERE direction IS NOT NULL AND direction != '' ORDER BY direction")
        directions = [row[0] for row in c.fetchall()]
        # Départements distincts
        c.execute("SELECT DISTINCT departement FROM personnel WHERE departement IS NOT NULL AND departement != '' ORDER BY departement")
        departements = [r[0] for r in c.fetchall()]
        # Services distincts
        c.execute("SELECT DISTINCT service FROM personnel WHERE service IS NOT NULL AND service != '' ORDER BY service")
        services = [r[0] for r in c.fetchall()]
        # Équipes distinctes
        c.execute("SELECT DISTINCT equipe FROM personnel WHERE equipe IS NOT NULL AND equipe != '' ORDER BY equipe")
        equipes = [r[0] for r in c.fetchall()]

    now = datetime.now()
    utiliser_globaux = db.get_parametre('utiliser_horaires_globaux', '0') == '1'
    return render_template('rapports/retards_filtres.html',
                           directions=directions,
                           departements=departements,
                           services=services,
                           equipes=equipes,
                           now=now,
                           utiliser_globaux=utiliser_globaux)
        

# Export PDF générique (à utiliser pour les rapports)
@app.route('/rapports/pdf', methods=['POST'])
@login_required
def exporter_rapport_pdf():
    from reportlab.lib.pagesizes import A4, landscape
    from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer, Image
    from reportlab.lib import colors
    from reportlab.lib.units import cm
    import json, os, tempfile

    data = request.get_json()
    titre = data.get('titre', 'Rapport')
    colonnes = data.get('colonnes', [])
    lignes = data.get('lignes', [])
    sous_titre = data.get('sous_titre', '')

    if not lignes:
        return jsonify({'success': False, 'message': 'Aucune donnée'}), 400

    # Orientation paysage si plus de 6 colonnes
    pagesize = landscape(A4) if len(colonnes) > 6 else A4

    # Fichier temporaire
    with tempfile.NamedTemporaryFile(delete=False, suffix='.pdf') as tmp:
        pdf_path = tmp.name
    

    doc = SimpleDocTemplate(pdf_path, pagesize=pagesize,
                            rightMargin=1.5*cm, leftMargin=1.5*cm,
                            topMargin=2*cm, bottomMargin=2*cm)

    styles = get_pdf_styles()
    elements = []

    # Logo
    
    # Avant doc.build, vérifier si le logo existe et l'ajouter
        
    logo_path = os.path.join('static', 'images', 'logo.png')
    if os.path.exists(logo_path):
        logo = Image(logo_path, width=3*cm, height=3*cm)
        elements.append(logo)
        elements.append(Spacer(1, 0.5*cm))

    # Titre
    elements.append(Paragraph(titre, styles['CustomTitle']))
    if sous_titre:
        elements.append(Paragraph(sous_titre, styles['Normal']))
    elements.append(Spacer(1, 0.5*cm))

    # Construction du tableau
    data_table = [colonnes] + lignes
    table = Table(data_table, repeatRows=1, hAlign='CENTER')

    # Style de base
    style = TableStyle([
        ('BACKGROUND', (0,0), (-1,0), colors.HexColor('#3498db')),  # bleu
        ('TEXTCOLOR', (0,0), (-1,0), colors.white),
        ('ALIGN', (0,0), (-1,-1), 'CENTER'),
        ('FONTNAME', (0,0), (-1,0), 'Helvetica-Bold'),
        ('FONTSIZE', (0,0), (-1,0), 11),
        ('BOTTOMPADDING', (0,0), (-1,0), 10),
        ('BACKGROUND', (0,1), (-1,-1), colors.HexColor('#f8f9fa')),  # gris clair
        ('GRID', (0,0), (-1,-1), 0.5, colors.grey),
        ('FONTSIZE', (0,1), (-1,-1), 9),
        ('VALIGN', (0,0), (-1,-1), 'MIDDLE'),
    ])

    # Alignement automatique des colonnes
    for i, col in enumerate(colonnes):
        if any(k in col.lower() for k in ('min', '€', 'id', 'nb', 'total', 'pénalité', 'jours')):
            style.add('ALIGN', (i,1), (i,-1), 'RIGHT')
        else:
            style.add('ALIGN', (i,1), (i,-1), 'LEFT')

    table.setStyle(style)
    elements.append(table)

    # Pied de page
    from datetime import datetime
    user = session.get('prenom', '') + ' ' + session.get('nom', '')
    def add_footer(canvas, doc):
        canvas.saveState()
        footer = f"Généré le {datetime.now().strftime('%d/%m/%Y %H:%M')} par {user} - Page {doc.page}"
        canvas.setFont('Helvetica', 8)
        canvas.drawCentredString(doc.pagesize[0]/2, 1.2*cm, footer)
        canvas.restoreState()

    doc.build(elements, onFirstPage=add_footer, onLaterPages=add_footer)

    return send_file(pdf_path, as_attachment=False, download_name="rapport.pdf")

