@app.route('/pointages')
@login_required
def liste_pointages():
    date_debut = request.args.get('date_debut', '')
    date_fin = request.args.get('date_fin', '')
    matricule = request.args.get('matricule', '')
    direction = request.args.get('direction', '')
    departement = request.args.get('departement', '')
    service = request.args.get('service', '')
    equipe = request.args.get('equipe', '')

    pointages = db.get_pointages_filtres(
        date_debut=date_debut,
        date_fin=date_fin,
        matricule=matricule,
        direction=direction,
        departement=departement,
        service=service,
        equipe=equipe
    )

    # Récupérer les listes pour les filtres
    directions = db.get_all_directions()
    with db.get_connection() as conn:
        c = conn.cursor()
        c.execute("SELECT DISTINCT departement FROM personnel WHERE departement IS NOT NULL ORDER BY departement")
        departements = [r[0] for r in c.fetchall()]
        c.execute("SELECT DISTINCT service FROM personnel WHERE service IS NOT NULL ORDER BY service")
        services = [r[0] for r in c.fetchall()]
        c.execute("SELECT DISTINCT equipe FROM personnel WHERE equipe IS NOT NULL ORDER BY equipe")
        equipes = [r[0] for r in c.fetchall()]

    return render_template('pointages/liste.html',
                           pointages=pointages,
                           date_debut=date_debut,
                           date_fin=date_fin,
                           matricule=matricule,
                           direction=direction,
                           departement=departement,
                           service=service,
                           equipe=equipe,
                           directions=directions,
                           departements=departements,
                           services=services,
                           equipes=equipes)

